        <mxCell id="Tj8YYApBm8QszppxP4FJ-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;src/&lt;/div&gt;&lt;div&gt;&amp;nbsp;├── components/&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Header.jsx&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Footer.jsx&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;└── Navigation.jsx&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&lt;/div&gt;&lt;div&gt;&amp;nbsp;├── layouts/&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;└── MainLayout.jsx&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&lt;/div&gt;&lt;div&gt;&amp;nbsp;├── pages/&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Home.jsx&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Search.jsx&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Unterkunft.jsx&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;├── Vermieter.jsx&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&amp;nbsp; &amp;nbsp; &amp;nbsp;└── Login.jsx&lt;/div&gt;&lt;div&gt;&amp;nbsp;│&lt;/div&gt;&lt;div&gt;&amp;nbsp;├── App.jsx&lt;/div&gt;&lt;div&gt;&amp;nbsp;└── main.jsx&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="290" width="200" x="-2200" y="-850" as="geometry" />
        </mxCell>
        <mxCell id="Tj8YYApBm8QszppxP4FJ-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;h1&gt;🧱 &lt;strong&gt;2. Header, Body, Footer als Komponenten&lt;/strong&gt;&lt;/h1&gt;&lt;h3&gt;🔹 Header.jsx&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;export default function Header() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;header&amp;gt;&lt;br/&gt;      &amp;lt;h1&amp;gt;Monteurland&amp;lt;/h1&amp;gt;&lt;br/&gt;      &amp;lt;nav&amp;gt;&lt;br/&gt;        &amp;lt;a href=&quot;/&quot;&amp;gt;Start&amp;lt;/a&amp;gt;&lt;br/&gt;        &amp;lt;a href=&quot;/search&quot;&amp;gt;Suche&amp;lt;/a&amp;gt;&lt;br/&gt;        &amp;lt;a href=&quot;/vermieter&quot;&amp;gt;Vermieter&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;/nav&amp;gt;&lt;br/&gt;    &amp;lt;/header&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h3&gt;🔹 Footer.jsx&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;export default function Footer() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;footer&amp;gt;&lt;br/&gt;      &amp;lt;p&amp;gt;© 2026 Monteurland&amp;lt;/p&amp;gt;&lt;br/&gt;    &amp;lt;/footer&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 &lt;strong&gt;3. Layout‑Komponente (sehr wichtig!)&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit du nicht in jeder Seite Header + Footer wiederholen musst:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;MainLayout.jsx&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import Header from &quot;../components/Header&quot;;&lt;br/&gt;import Footer from &quot;../components/Footer&quot;;&lt;br/&gt;&lt;br/&gt;export default function MainLayout({ children }) {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;&amp;gt;&lt;br/&gt;      &amp;lt;Header /&amp;gt;&lt;br/&gt;      &amp;lt;main&amp;gt;{children}&amp;lt;/main&amp;gt;&lt;br/&gt;      &amp;lt;Footer /&amp;gt;&lt;br/&gt;    &amp;lt;/&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🚀 &lt;strong&gt;4. Seiten einbinden (React Router)&lt;/strong&gt;&lt;/h1&gt;&lt;h3&gt;App.jsx&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { BrowserRouter, Routes, Route } from &quot;react-router-dom&quot;;&lt;br/&gt;import MainLayout from &quot;./layouts/MainLayout&quot;;&lt;br/&gt;&lt;br/&gt;import Home from &quot;./pages/Home&quot;;&lt;br/&gt;import Search from &quot;./pages/Search&quot;;&lt;br/&gt;import Unterkunft from &quot;./pages/Unterkunft&quot;;&lt;br/&gt;&lt;br/&gt;export default function App() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;BrowserRouter&amp;gt;&lt;br/&gt;      &amp;lt;MainLayout&amp;gt;&lt;br/&gt;        &amp;lt;Routes&amp;gt;&lt;br/&gt;          &amp;lt;Route path=&quot;/&quot; element={&amp;lt;Home /&amp;gt;} /&amp;gt;&lt;br/&gt;          &amp;lt;Route path=&quot;/search&quot; element={&amp;lt;Search /&amp;gt;} /&amp;gt;&lt;br/&gt;          &amp;lt;Route path=&quot;/unterkunft/:id&quot; element={&amp;lt;Unterkunft /&amp;gt;} /&amp;gt;&lt;br/&gt;        &amp;lt;/Routes&amp;gt;&lt;br/&gt;      &amp;lt;/MainLayout&amp;gt;&lt;br/&gt;    &amp;lt;/BrowserRouter&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🏡 &lt;strong&gt;5. Beispielseite (Home.jsx)&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;export default function Home() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div&amp;gt;&lt;br/&gt;      &amp;lt;h2&amp;gt;Finde Monteurzimmer in deiner Nähe&amp;lt;/h2&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔥 &lt;strong&gt;6. Warum diese Struktur perfekt ist&lt;/strong&gt;&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Header/Footer sind &lt;strong&gt;global&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Jede Seite bekommt automatisch das Layout&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du kannst später:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Login‑Bereich&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Vermieter‑Dashboard&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Suchfilter&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Kartenansicht&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;API‑Anbindung (PHP Backend)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;problemlos erweitern&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;Wenn du willst, baue ich dir:&lt;/strong&gt;&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;eine komplette &lt;strong&gt;Startseite wie monteurzimmer.de&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;ein &lt;strong&gt;Suchformular&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;eine &lt;strong&gt;Kartenansicht (Leaflet oder Google Maps)&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;eine &lt;strong&gt;API‑Struktur in PHP (OOP)&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;ein &lt;strong&gt;Datenbankmodell für Unterkünfte&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, welchen Teil du als Nächstes brauchst.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="1990" width="570" x="-2780" y="-850" as="geometry" />
        </mxCell>
        <mxCell id="Tj8YYApBm8QszppxP4FJ-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Genau, Alexej — &lt;strong&gt;das Layout ist im Grunde dein „Body‑Gerüst“&lt;/strong&gt;, also der Rahmen, in dem alle Seiten angezeigt werden.&lt;br/&gt;In React nennt man das &lt;strong&gt;Layout‑Komponente&lt;/strong&gt;, aber funktional ist es genau das, was früher in HTML der &lt;code&gt;&amp;lt;body&amp;gt;&lt;/code&gt;‑Bereich war.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich zeige dir das einmal ganz klar und verständlich.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧱 &lt;strong&gt;Was ist was? (React vs. klassisches HTML)&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div tabindex=&quot;0&quot; role=&quot;group&quot; aria-label=&quot;Scrollbare Tabelle&quot;&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Klassisches HTML&lt;/th&gt;&lt;th&gt;React&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;code&gt;&lt;header&gt;&lt;/header&gt;&lt;/code&gt;&lt;/td&gt;&lt;td&gt;Header‑Komponente&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;code&gt;&lt;main&gt;&lt;/main&gt;&lt;/code&gt;&lt;/td&gt;&lt;td&gt;Layout‑Komponente (&lt;code&gt;children&lt;/code&gt;)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;code&gt;&lt;footer&gt;&lt;/footer&gt;&lt;/code&gt;&lt;/td&gt;&lt;td&gt;Footer‑Komponente&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;code&gt;&lt;/code&gt;&lt;/td&gt;&lt;td&gt;&lt;strong&gt;Layout&lt;/strong&gt; (alles zusammen)&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;button aria-label=&quot;Tabelle kopieren&quot; type=&quot;button&quot; data-testid=&quot;copy-table-button&quot; data-spatial-navigation-autofocus=&quot;false&quot; data-tooltip-state=&quot;closed&quot;&gt;&lt;svg viewBox=&quot;0 0 20 20&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8 2C6.89543 2 6 2.89543 6 4V14C6 15.1046 6.89543 16 8 16H14C15.1046 16 16 15.1046 16 14V4C16 2.89543 15.1046 2 14 2H8ZM7 4C7 3.44772 7.44772 3 8 3H14C14.5523 3 15 3.44772 15 4V14C15 14.5523 14.5523 15 14 15H8C7.44772 15 7 14.5523 7 14V4ZM4 6.00001C4 5.25973 4.4022 4.61339 5 4.26758V14.5C5 15.8807 6.11929 17 7.5 17H13.7324C13.3866 17.5978 12.7403 18 12 18H7.5C5.567 18 4 16.433 4 14.5V6.00001Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;button aria-label=&quot;Tabelle herunterladen&quot; type=&quot;button&quot; data-testid=&quot;download-table-button&quot; data-spatial-navigation-autofocus=&quot;false&quot; data-tooltip-state=&quot;closed&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M18.2498 20.5009C18.664 20.5008 19 20.8365 19 21.2507C19 21.6649 18.6644 22.0008 18.2502 22.0009L5.25022 22.0047C4.836 22.0048 4.5 21.6691 4.5 21.2549C4.5 20.8407 4.83557 20.5048 5.24978 20.5047L18.2498 20.5009ZM11.6482 2.01271L11.75 2.00586C12.1297 2.00586 12.4435 2.28801 12.4932 2.65409L12.5 2.75586L12.499 16.4409L16.2208 12.7205C16.4871 12.4543 16.9038 12.4301 17.1974 12.648L17.2815 12.7206C17.5477 12.9869 17.5719 13.4036 17.354 13.6972L17.2814 13.7813L12.2837 18.7779C12.0176 19.044 11.6012 19.0683 11.3076 18.8507L11.2235 18.7782L6.22003 13.7816C5.92694 13.4889 5.92661 13.014 6.21931 12.7209C6.48539 12.4545 6.90204 12.43 7.1958 12.6477L7.27997 12.7202L10.999 16.4339L11 2.75586C11 2.37616 11.2822 2.06237 11.6482 2.01271L11.75 2.00586L11.6482 2.01271Z&quot; fill=&quot;currentColor&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das heißt:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 &lt;strong&gt;Dein Layout = dein Body&lt;/strong&gt;  &lt;br/&gt;👉 &lt;strong&gt;Header + Footer = feste Teile&lt;/strong&gt;  &lt;br/&gt;👉 &lt;strong&gt;children = wechselnder Seiteninhalt&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;So sieht ein echtes React‑Layout aus&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ist dein „Body“:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;&lt;code&gt;MainLayout.jsx&lt;/code&gt;&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import Header from &quot;../components/Header&quot;;&lt;br/&gt;import Footer from &quot;../components/Footer&quot;;&lt;br/&gt;&lt;br/&gt;export default function MainLayout({ children }) {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;layout&quot;&amp;gt;&lt;br/&gt;      &amp;lt;Header /&amp;gt;&lt;br/&gt;      &lt;br/&gt;      &amp;lt;main className=&quot;content&quot;&amp;gt;&lt;br/&gt;        {children}   {/* Das ist dein Body-Inhalt */}&lt;br/&gt;      &amp;lt;/main&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;Footer /&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔️ Header oben&lt;br/&gt;✔️ Footer unten&lt;br/&gt;✔️ Alles dazwischen = Body (dynamisch)&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔥 &lt;strong&gt;Wie wird das Layout benutzt?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;In deiner &lt;code&gt;App.jsx&lt;/code&gt;:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { BrowserRouter, Routes, Route } from &quot;react-router-dom&quot;;&lt;br/&gt;import MainLayout from &quot;./layouts/MainLayout&quot;;&lt;br/&gt;&lt;br/&gt;import Home from &quot;./pages/Home&quot;;&lt;br/&gt;import Search from &quot;./pages/Search&quot;;&lt;br/&gt;&lt;br/&gt;export default function App() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;BrowserRouter&amp;gt;&lt;br/&gt;      &amp;lt;MainLayout&amp;gt;&lt;br/&gt;        &amp;lt;Routes&amp;gt;&lt;br/&gt;          &amp;lt;Route path=&quot;/&quot; element={&amp;lt;Home /&amp;gt;} /&amp;gt;&lt;br/&gt;          &amp;lt;Route path=&quot;/search&quot; element={&amp;lt;Search /&amp;gt;} /&amp;gt;&lt;br/&gt;        &amp;lt;/Routes&amp;gt;&lt;br/&gt;      &amp;lt;/MainLayout&amp;gt;&lt;br/&gt;    &amp;lt;/BrowserRouter&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit passiert Folgendes:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Header bleibt immer gleich&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Footer bleibt immer gleich&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der Inhalt in &lt;code&gt;{children}&lt;/code&gt; wechselt je nach Route&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ist dein &lt;strong&gt;Body‑Bereich&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 &lt;strong&gt;Beispiel: Home.jsx (Body‑Inhalt)&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;export default function Home() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div&amp;gt;&lt;br/&gt;      &amp;lt;h2&amp;gt;Monteurland – Unterkünfte finden&amp;lt;/h2&amp;gt;&lt;br/&gt;      &amp;lt;p&amp;gt;Suche Monteurzimmer in deiner Nähe.&amp;lt;/p&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das landet automatisch im Body‑Bereich des Layouts.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;Kurz gesagt&lt;/strong&gt;&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Layout = Body‑Struktur&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Header/Footer = feste Komponenten&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;children = dynamischer Seiteninhalt&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;React Router lädt die Seiten in das Layout hinein&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, kann ich dir:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;ein komplettes &lt;strong&gt;Monteurland‑Layout&lt;/strong&gt; bauen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;mit &lt;strong&gt;Header‑Navigation&lt;/strong&gt;, &lt;strong&gt;Suchfeld&lt;/strong&gt;, &lt;strong&gt;Hero‑Bereich&lt;/strong&gt;, &lt;strong&gt;Footer&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;so wie monteurzimmer.de, aber moderner&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag einfach Bescheid, wie dein Design aussehen soll.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="1860" width="790" x="-2990" y="1220" as="geometry" />
        </mxCell>
