 src/components/header/RoleNavigation/GuestNav.jsx&lt;br/&gt;export default function GuestNav() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;nav className=&quot;me-3&quot;&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/login&quot; className=&quot;me-3&quot;&amp;gt;Login&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/register&quot;&amp;gt;Registrieren&amp;lt;/a&amp;gt;&lt;br/&gt;    &amp;lt;/nav&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;⭐ &lt;strong&gt;10. GesuchterNav.jsx&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/components/header/RoleNavigation/GesuchterNav.jsx&lt;br/&gt;export default function GesuchterNav() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;nav className=&quot;me-3&quot;&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/gesuchter/profile&quot; className=&quot;me-3&quot;&amp;gt;Profil&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/gesuchter/favoriten&quot; className=&quot;me-3&quot;&amp;gt;Favoriten&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/gesuchter/anfragen&quot;&amp;gt;Anfragen&amp;lt;/a&amp;gt;&lt;br/&gt;    &amp;lt;/nav&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;⭐ &lt;strong&gt;11. VermieterNav.jsx&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/components/header/RoleNavigation/VermieterNav.jsx&lt;br/&gt;export default function VermieterNav() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;nav className=&quot;me-3&quot;&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/vermieter/dashboard&quot; className=&quot;me-3&quot;&amp;gt;Dashboard&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/vermieter/inserat-erstellen&quot; className=&quot;me-3&quot;&amp;gt;Inserat erstellen&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/vermieter/buchungen&quot;&amp;gt;Buchungen&amp;lt;/a&amp;gt;&lt;br/&gt;    &amp;lt;/nav&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;⭐ &lt;strong&gt;12. AdminNav.jsx&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/components/header/RoleNavigation/AdminNav.jsx&lt;br/&gt;export default function AdminNav() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;nav className=&quot;me-3&quot;&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/admin&quot; className=&quot;me-3&quot;&amp;gt;Dashboard&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/admin/users&quot; className=&quot;me-3&quot;&amp;gt;Benutzer&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/admin/logs&quot; className=&quot;me-3&quot;&amp;gt;Logs&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/admin/settings&quot;&amp;gt;Einstellungen&amp;lt;/a&amp;gt;&lt;br/&gt;    &amp;lt;/nav&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 Fertig!&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du hast jetzt:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ kompletten Header&lt;br/&gt;✔ alle Unterkomponenten&lt;br/&gt;✔ Rollen‑Navigation&lt;br/&gt;✔ Bootstrap‑kompatibel&lt;br/&gt;✔ sofort einsatzbereit&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, können wir als Nächstes:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 den kompletten &lt;strong&gt;Footer&lt;/strong&gt; bauen&lt;br/&gt;👉 den &lt;strong&gt;AuthContext&lt;/strong&gt; erstellen (Login + Rollen)&lt;br/&gt;👉 die &lt;strong&gt;ProtectedRoute&lt;/strong&gt; richtig anbinden&lt;br/&gt;👉 oder das &lt;strong&gt;Design verbessern&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, was du als Nächstes brauchst.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="4090" width="680" x="-9710" y="-10750" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-11" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der &lt;strong&gt;Footer wird automatisch im &lt;/strong&gt;&lt;code&gt;MainLayout&lt;/code&gt;&lt;strong&gt; aufgerufen&lt;/strong&gt;, genau wie der Header.&lt;br/&gt;Das bedeutet: &lt;strong&gt;jede Seite, die innerhalb von &lt;/strong&gt;&lt;code&gt;&amp;lt;MainLayout&amp;gt;&lt;/code&gt;&lt;strong&gt; gerendert wird, bekommt automatisch den Footer darunter angezeigt.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du hast ihn hier eingebunden:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;Wo der Footer aufgerufen wird (MainLayout.jsx)&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/layouts/MainLayout.jsx&lt;br/&gt;import Header from &quot;../components/header/Header&quot;;&lt;br/&gt;import Footer from &quot;../components/footer/Footer&quot;;&lt;br/&gt;&lt;br/&gt;export default function MainLayout({ children }) {&lt;br/&gt;  const role = &quot;guest&quot;;&lt;br/&gt;  const user = null;&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;d-flex flex-column min-vh-100&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;Header role={role} user={user} /&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;main className=&quot;flex-grow-1 container py-4&quot;&amp;gt;&lt;br/&gt;        {children}&lt;br/&gt;      &amp;lt;/main&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;Footer /&amp;gt;   {/* ⬅️ HIER wird der Footer aufgerufen */}&lt;br/&gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔍 &lt;strong&gt;Was bedeutet das?&lt;/strong&gt;&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Jede Seite (&lt;code&gt;Home&lt;/code&gt;, &lt;code&gt;Search&lt;/code&gt;, &lt;code&gt;Login&lt;/code&gt;, &lt;code&gt;gesuchter/...&lt;/code&gt;, &lt;code&gt;vermieter/...&lt;/code&gt;, &lt;code&gt;admin/...&lt;/code&gt;)&lt;br/&gt;wird &lt;strong&gt;innerhalb von MainLayout&lt;/strong&gt; gerendert.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Dadurch erscheinen &lt;strong&gt;Header oben&lt;/strong&gt; und &lt;strong&gt;Footer unten&lt;/strong&gt; automatisch auf jeder Seite.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧠 &lt;strong&gt;Wie fließt das zusammen?&lt;/strong&gt;&lt;/h1&gt;&lt;h3&gt;&lt;code&gt;main.jsx&lt;/code&gt; → rendert &lt;code&gt;App&lt;/code&gt;&lt;/h3&gt;&lt;h3&gt;&lt;code&gt;App.jsx&lt;/code&gt; → rendert &lt;code&gt;MainLayout&lt;/code&gt;&lt;/h3&gt;&lt;h3&gt;&lt;code&gt;MainLayout.jsx&lt;/code&gt; → rendert:&lt;/h3&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Header&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Seiteninhalt (&lt;code&gt;children&lt;/code&gt;)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Footer&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📌 Beispielfluss&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du &lt;code&gt;/search&lt;/code&gt; aufrufst:&lt;/span&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;AppRouter&lt;/code&gt; rendert &lt;code&gt;&amp;lt;Search /&amp;gt;&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;App.jsx&lt;/code&gt; packt &lt;code&gt;&amp;lt;Search /&amp;gt;&lt;/code&gt; in &lt;code&gt;&amp;lt;MainLayout&amp;gt;&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;MainLayout&lt;/code&gt; rendert:&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;Header&lt;br/&gt;Search (Seiteninhalt)&lt;br/&gt;Footer&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, kann ich dir auch zeigen:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 wie man &lt;strong&gt;Footer nur auf bestimmten Seiten&lt;/strong&gt; anzeigt&lt;br/&gt;👉 wie man &lt;strong&gt;Sticky Footer&lt;/strong&gt; baut&lt;br/&gt;👉 wie man &lt;strong&gt;Dark Mode&lt;/strong&gt; für Header/Footer einrichtet&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag einfach Bescheid.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="1210" width="740" x="-8920" y="-12790" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-12" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;h1&gt;🔥 &lt;strong&gt;Was noch fehlt, um das Projekt wirklich fertig zu haben&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich teile es in &lt;strong&gt;Pflicht&lt;/strong&gt; und &lt;strong&gt;Optional&lt;/strong&gt; ein.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🟢 &lt;strong&gt;Pflicht (damit alles funktioniert)&lt;/strong&gt;&lt;/h1&gt;&lt;h2&gt;&lt;strong&gt;1. AuthContext (Login, Logout, Rolle speichern)&lt;/strong&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit ProtectedRoute, Header, UserMenu und RoleNavigation wirklich funktionieren.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du brauchst:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;AuthContext.jsx&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;useAuth()&lt;/code&gt; Hook&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Login‑Funktion&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Logout‑Funktion&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Rolle speichern (guest, gesuchter, vermieter, admin)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ohne das bleibt alles statisch.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;&lt;strong&gt;2. ProtectedRoute richtig anbinden&lt;/strong&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Aktuell prüft ProtectedRoute nur eine Fake‑Rolle.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du musst:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;useAuth()&lt;/code&gt; integrieren&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Redirects sauber machen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Optional: mehrere Rollen erlauben&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;&lt;strong&gt;3. Login‑Seite mit echter Logik&lt;/strong&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Aktuell ist Login.jsx nur ein Formular.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du brauchst:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;onSubmit Handler&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Login‑Funktion aus AuthContext aufrufen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Rolle setzen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Redirect nach Login&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;&lt;strong&gt;4. Navigation dynamisch machen&lt;/strong&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Header zeigt aktuell immer dieselben Links.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Mit AuthContext soll er:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;bei Login → UserMenu anzeigen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;bei Logout → Login‑Button anzeigen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Rolle wechseln → RoleNavigation aktualisieren&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;&lt;strong&gt;5. Fehlerseiten&lt;/strong&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Mindestens:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;NotFound.jsx&lt;/code&gt; (404)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;optional: &lt;code&gt;Unauthorized.jsx&lt;/code&gt; (403)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Und im Router einbauen.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🟡 &lt;strong&gt;Optional (aber sehr sinnvoll)&lt;/strong&gt;&lt;/h1&gt;&lt;h2&gt;&lt;strong&gt;6. API‑Service / Backend‑Anbindung&lt;/strong&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Falls du später Daten laden willst:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;services/api.js&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Login‑Request&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Daten für Profile, Inserate, Buchungen usw.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;&lt;strong&gt;7. Common Components erweitern&lt;/strong&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;z. B.:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Modal&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alert&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Pagination&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Table&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;&lt;strong&gt;8. Styling verbessern&lt;/strong&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bootstrap ist da, aber du kannst:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;eigenes Theme&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;SCSS&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Utility‑Klassen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Dark Mode&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;&lt;strong&gt;9. Mobile Navigation (MobileMenu)&lt;/strong&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Aktuell ist MobileMenu nur ein Button.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du kannst:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Offcanvas Menü&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Hamburger Menü&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Mobile RoleNavigation&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;&lt;strong&gt;10. SEO / Meta Tags&lt;/strong&gt;&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Optional:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;React Helmet&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Titel pro Seite&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;Kurz gesagt:&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Um dein &lt;code&gt;src/&lt;/code&gt; wirklich &lt;strong&gt;fertig&lt;/strong&gt; zu haben, brauchst du noch:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;&lt;strong&gt;Pflicht&lt;/strong&gt;&lt;/h3&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;AuthContext&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;useAuth Hook&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Login‑Logik&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;ProtectedRoute finalisieren&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Dynamische Navigation&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Fehlerseiten&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;h3&gt;&lt;strong&gt;Optional&lt;/strong&gt;&lt;/h3&gt;&lt;ol start=&quot;7&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;API‑Service&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Common UI erweitern&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Mobile Menü&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;SEO&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Was möchtest du als Nächstes machen?&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich empfehle &lt;strong&gt;AuthContext + useAuth()&lt;/strong&gt; als nächsten Schritt, weil:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Header wird dynamisch&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;ProtectedRoute funktioniert&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Login funktioniert&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Rollen funktionieren&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach:&lt;br/&gt;&lt;strong&gt;Sollen wir jetzt den AuthContext bauen?&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="2610" width="740" x="-8920" y="-11540" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-13" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Perfekt — dann bauen wir jetzt &lt;strong&gt;Schritt für Schritt deinen AuthContext&lt;/strong&gt;, so wie man es in einer echten, professionellen App macht.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich gebe dir:&lt;/span&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;AuthContext.jsx&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;useAuth.js Hook&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Login‑/Logout‑Funktionen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Rolle speichern (guest, gesuchter, vermieter, admin)&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Persistenz über localStorage&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Integration in App.jsx&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles sauber, modular und sofort nutzbar.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ 1. &lt;code&gt;src/context/AuthContext.jsx&lt;/code&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ist das Herzstück deiner Authentifizierung.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { createContext, useState, useEffect } from &quot;react&quot;;&lt;br/&gt;&lt;br/&gt;export const AuthContext = createContext();&lt;br/&gt;&lt;br/&gt;export default function AuthProvider({ children }) {&lt;br/&gt;  const [user, setUser] = useState(null);&lt;br/&gt;  const [role, setRole] = useState(&quot;guest&quot;);&lt;br/&gt;&lt;br/&gt;  // Beim Laden: Daten aus localStorage holen&lt;br/&gt;  useEffect(() =&amp;gt; {&lt;br/&gt;    const savedUser = localStorage.getItem(&quot;user&quot;);&lt;br/&gt;    const savedRole = localStorage.getItem(&quot;role&quot;);&lt;br/&gt;&lt;br/&gt;    if (savedUser) setUser(JSON.parse(savedUser));&lt;br/&gt;    if (savedRole) setRole(savedRole);&lt;br/&gt;  }, []);&lt;br/&gt;&lt;br/&gt;  // Login-Funktion&lt;br/&gt;  const login = (email, password) =&amp;gt; {&lt;br/&gt;    // Beispiel: Fake-Login&lt;br/&gt;    // Später ersetzt du das durch API-Call&lt;br/&gt;&lt;br/&gt;    // Beispiel: Rolle anhand der E-Mail bestimmen&lt;br/&gt;    let detectedRole = &quot;gesuchter&quot;;&lt;br/&gt;&lt;br/&gt;    if (email === &quot;vermieter@test.de&quot;) detectedRole = &quot;vermieter&quot;;&lt;br/&gt;    if (email === &quot;admin@test.de&quot;) detectedRole = &quot;admin&quot;;&lt;br/&gt;&lt;br/&gt;    const loggedUser = { email };&lt;br/&gt;&lt;br/&gt;    setUser(loggedUser);&lt;br/&gt;    setRole(detectedRole);&lt;br/&gt;&lt;br/&gt;    localStorage.setItem(&quot;user&quot;, JSON.stringify(loggedUser));&lt;br/&gt;    localStorage.setItem(&quot;role&quot;, detectedRole);&lt;br/&gt;&lt;br/&gt;    return true;&lt;br/&gt;  };&lt;br/&gt;&lt;br/&gt;  // Logout-Funktion&lt;br/&gt;  const logout = () =&amp;gt; {&lt;br/&gt;    setUser(null);&lt;br/&gt;    setRole(&quot;guest&quot;);&lt;br/&gt;    localStorage.removeItem(&quot;user&quot;);&lt;br/&gt;    localStorage.removeItem(&quot;role&quot;);&lt;br/&gt;  };&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;AuthContext.Provider value={{ user, role, login, logout }}&amp;gt;&lt;br/&gt;      {children}&lt;br/&gt;    &amp;lt;/AuthContext.Provider&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ 2. &lt;code&gt;src/hooks/useAuth.js&lt;/code&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ein Hook, damit du überall einfach &lt;code&gt;useAuth()&lt;/code&gt; nutzen kannst.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { useContext } from &quot;react&quot;;&lt;br/&gt;import { AuthContext } from &quot;../context/AuthContext&quot;;&lt;br/&gt;&lt;br/&gt;export function useAuth() {&lt;br/&gt;  return useContext(AuthContext);&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ 3. Integration in &lt;code&gt;App.jsx&lt;/code&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit der AuthContext überall verfügbar ist.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import MainLayout from &quot;./layouts/MainLayout&quot;;&lt;br/&gt;import AppRouter from &quot;./router/AppRouter&quot;;&lt;br/&gt;import AuthProvider from &quot;./context/AuthContext&quot;;&lt;br/&gt;&lt;br/&gt;export default function App() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;AuthProvider&amp;gt;&lt;br/&gt;      &amp;lt;MainLayout&amp;gt;&lt;br/&gt;        &amp;lt;AppRouter /&amp;gt;&lt;br/&gt;      &amp;lt;/MainLayout&amp;gt;&lt;br/&gt;    &amp;lt;/AuthProvider&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ 4. ProtectedRoute aktualisieren&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Jetzt nutzen wir echte Auth-Daten.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { Navigate } from &quot;react-router-dom&quot;;&lt;br/&gt;import { useAuth } from &quot;../hooks/useAuth&quot;;&lt;br/&gt;&lt;br/&gt;export default function ProtectedRoute({ children, role }) {&lt;br/&gt;  const { user, role: userRole } = useAuth();&lt;br/&gt;&lt;br/&gt;  if (!user) {&lt;br/&gt;    return &amp;lt;Navigate to=&quot;/login&quot; replace /&amp;gt;;&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  if (userRole !== role) {&lt;br/&gt;    return &amp;lt;Navigate to=&quot;/unauthorized&quot; replace /&amp;gt;;&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  return children;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ 5. Login.jsx aktualisieren (mit echter Logik)&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit Login wirklich funktioniert.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { useState } from &quot;react&quot;;&lt;br/&gt;import { useAuth } from &quot;../hooks/useAuth&quot;;&lt;br/&gt;import { useNavigate } from &quot;react-router-dom&quot;;&lt;br/&gt;&lt;br/&gt;export default function Login() {&lt;br/&gt;  const { login } = useAuth();&lt;br/&gt;  const navigate = useNavigate();&lt;br/&gt;&lt;br/&gt;  const [email, setEmail] = useState(&quot;&quot;);&lt;br/&gt;  const [password, setPassword] = useState(&quot;&quot;);&lt;br/&gt;&lt;br/&gt;  const handleSubmit = (e) =&amp;gt; {&lt;br/&gt;    e.preventDefault();&lt;br/&gt;&lt;br/&gt;    const success = login(email, password);&lt;br/&gt;&lt;br/&gt;    if (success) {&lt;br/&gt;      navigate(&quot;/&quot;);&lt;br/&gt;    }&lt;br/&gt;  };&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;col-md-6 mx-auto&quot;&amp;gt;&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Login&amp;lt;/h1&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;form onSubmit={handleSubmit}&amp;gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;E-Mail&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;input&lt;br/&gt;            type=&quot;email&quot;&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            value={email}&lt;br/&gt;            onChange={(e) =&amp;gt; setEmail(e.target.value)}&lt;br/&gt;            placeholder=&quot;email@example.com&quot;&lt;br/&gt;          /&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Passwort&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;input&lt;br/&gt;            type=&quot;password&quot;&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            value={password}&lt;br/&gt;            onChange={(e) =&amp;gt; setPassword(e.target.value)}&lt;br/&gt;            placeholder=&quot;••••••••&quot;&lt;br/&gt;          /&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;button type=&quot;submit&quot; className=&quot;btn btn-primary w-100&quot;&amp;gt;&lt;br/&gt;          Einloggen&lt;br/&gt;        &amp;lt;/button&amp;gt;&lt;br/&gt;      &amp;lt;/form&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 Jetzt hast du:&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ echten AuthContext&lt;br/&gt;✔ Login / Logout&lt;br/&gt;✔ Rollenverwaltung&lt;br/&gt;✔ Persistenz über localStorage&lt;br/&gt;✔ ProtectedRoute mit echter Logik&lt;br/&gt;✔ Header kann jetzt dynamisch werden&lt;br/&gt;✔ UserMenu kann Logout anzeigen&lt;br/&gt;✔ RoleNavigation funktioniert automatisch&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Was machen wir als Nächstes?&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich empfehle:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;&lt;strong&gt;2. ProtectedRoute finalisieren + Unauthorized-Seite bauen&lt;/strong&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;oder&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;&lt;strong&gt;3. Header dynamisch machen (UserMenu + RoleNavigation)&lt;/strong&gt;&lt;/h3&gt;" vertex="1">
          <mxGeometry height="3300" width="680" x="-8890" y="-8880" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-15" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — hier kommt &lt;strong&gt;der komplette Footer&lt;/strong&gt; mit allen Komponenten, perfekt passend zu deiner Struktur:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;components/&lt;br/&gt; └── footer/&lt;br/&gt;       ├── Footer.jsx&lt;br/&gt;       ├── FooterLinks.jsx&lt;br/&gt;       ├── SocialLinks.jsx&lt;br/&gt;       ├── ContactInfo.jsx&lt;br/&gt;       └── LegalLinks.jsx&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich baue dir einen &lt;strong&gt;professionellen, responsiven Footer&lt;/strong&gt;, der mit Bootstrap funktioniert und sauber modular aufgebaut ist.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;⭐ 1. &lt;code&gt;Footer.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/components/footer/Footer.jsx&lt;br/&gt;import FooterLinks from &quot;./FooterLinks&quot;;&lt;br/&gt;import SocialLinks from &quot;./SocialLinks&quot;;&lt;br/&gt;import ContactInfo from &quot;./ContactInfo&quot;;&lt;br/&gt;import LegalLinks from &quot;./LegalLinks&quot;;&lt;br/&gt;&lt;br/&gt;export default function Footer() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;footer className=&quot;bg-dark text-light mt-5 pt-4 pb-3&quot;&amp;gt;&lt;br/&gt;      &amp;lt;div className=&quot;container&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;row mb-4&quot;&amp;gt;&lt;br/&gt;          &amp;lt;div className=&quot;col-md-4 mb-3&quot;&amp;gt;&lt;br/&gt;            &amp;lt;h5 className=&quot;text-uppercase&quot;&amp;gt;Navigation&amp;lt;/h5&amp;gt;&lt;br/&gt;            &amp;lt;FooterLinks /&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;          &amp;lt;div className=&quot;col-md-4 mb-3&quot;&amp;gt;&lt;br/&gt;            &amp;lt;h5 className=&quot;text-uppercase&quot;&amp;gt;Kontakt&amp;lt;/h5&amp;gt;&lt;br/&gt;            &amp;lt;ContactInfo /&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;          &amp;lt;div className=&quot;col-md-4 mb-3&quot;&amp;gt;&lt;br/&gt;            &amp;lt;h5 className=&quot;text-uppercase&quot;&amp;gt;Folge uns&amp;lt;/h5&amp;gt;&lt;br/&gt;            &amp;lt;SocialLinks /&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;border-top pt-3 text-center&quot;&amp;gt;&lt;br/&gt;          &amp;lt;LegalLinks /&amp;gt;&lt;br/&gt;          &amp;lt;p className=&quot;mt-2 mb-0&quot;&amp;gt;© {new Date().getFullYear()} MeineApp. Alle Rechte vorbehalten.&amp;lt;/p&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;    &amp;lt;/footer&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;⭐ 2. &lt;code&gt;FooterLinks.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/components/footer/FooterLinks.jsx&lt;br/&gt;export default function FooterLinks() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;ul className=&quot;list-unstyled&quot;&amp;gt;&lt;br/&gt;      &amp;lt;li&amp;gt;&amp;lt;a href=&quot;/&quot; className=&quot;text-light text-decoration-none&quot;&amp;gt;Home&amp;lt;/a&amp;gt;&amp;lt;/li&amp;gt;&lt;br/&gt;      &amp;lt;li&amp;gt;&amp;lt;a href=&quot;/search&quot; className=&quot;text-light text-decoration-none&quot;&amp;gt;Suche&amp;lt;/a&amp;gt;&amp;lt;/li&amp;gt;&lt;br/&gt;      &amp;lt;li&amp;gt;&amp;lt;a href=&quot;/login&quot; className=&quot;text-light text-decoration-none&quot;&amp;gt;Login&amp;lt;/a&amp;gt;&amp;lt;/li&amp;gt;&lt;br/&gt;    &amp;lt;/ul&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;⭐ 3. &lt;code&gt;SocialLinks.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/components/footer/SocialLinks.jsx&lt;br/&gt;export default function SocialLinks() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;d-flex gap-3&quot;&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;#&quot; className=&quot;text-light fs-4&quot;&amp;gt;🌐&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;#&quot; className=&quot;text-light fs-4&quot;&amp;gt;📘&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;#&quot; className=&quot;text-light fs-4&quot;&amp;gt;🐦&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;#&quot; className=&quot;text-light fs-4&quot;&amp;gt;📸&amp;lt;/a&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;⭐ 4. &lt;code&gt;ContactInfo.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/components/footer/ContactInfo.jsx&lt;br/&gt;export default function ContactInfo() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;ul className=&quot;list-unstyled&quot;&amp;gt;&lt;br/&gt;      &amp;lt;li&amp;gt;Email: support@meineapp.de&amp;lt;/li&amp;gt;&lt;br/&gt;      &amp;lt;li&amp;gt;Telefon: +49 123 456789&amp;lt;/li&amp;gt;&lt;br/&gt;      &amp;lt;li&amp;gt;Adresse: Musterstraße 1, 12345 Berlin&amp;lt;/li&amp;gt;&lt;br/&gt;    &amp;lt;/ul&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;⭐ 5. &lt;code&gt;LegalLinks.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/components/footer/LegalLinks.jsx&lt;br/&gt;export default function LegalLinks() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;d-flex justify-content-center gap-4&quot;&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/impressum&quot; className=&quot;text-light text-decoration-none&quot;&amp;gt;Impressum&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/datenschutz&quot; className=&quot;text-light text-decoration-none&quot;&amp;gt;Datenschutz&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/agb&quot; className=&quot;text-light text-decoration-none&quot;&amp;gt;AGB&amp;lt;/a&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 Fertig!&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du hast jetzt:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ kompletten Footer&lt;br/&gt;✔ modular aufgebaut&lt;br/&gt;✔ Bootstrap‑ready&lt;br/&gt;✔ responsive&lt;br/&gt;✔ sofort einsatzbereit&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, können wir als Nächstes:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 den &lt;strong&gt;AuthContext&lt;/strong&gt; bauen&lt;br/&gt;👉 die &lt;strong&gt;ProtectedRoute&lt;/strong&gt; richtig mit Login verbinden&lt;br/&gt;👉 die &lt;strong&gt;gesuchter/vermieter/admin&lt;/strong&gt; Seiten mit Inhalt füllen&lt;br/&gt;👉 oder das &lt;strong&gt;Design verbessern&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag einfach, wie wir weitermachen.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="2110" width="740" x="-8920" y="-14980" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-16" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — wir bauen jetzt &lt;strong&gt;eine vollständige Mobile Navigation&lt;/strong&gt;, die:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;auf kleinen Screens ein Hamburger‑Menü zeigt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;ein &lt;strong&gt;Offcanvas‑Menü&lt;/strong&gt; (seitliches Menü) öffnet&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;automatisch die &lt;strong&gt;richtige Rollen‑Navigation&lt;/strong&gt; lädt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;perfekt zu deinem bestehenden Header passt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Und das Ganze &lt;strong&gt;ohne Chaos&lt;/strong&gt;, sauber modular.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📱 &lt;strong&gt;Zielbild der Mobile Navigation&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Auf Desktop:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Header bleibt wie er ist&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Auf Mobile:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Links verschwinden&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Hamburger‑Button erscheint&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beim Klick öffnet sich ein Offcanvas‑Menü mit:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Navigation&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Rollen‑Navigation&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;UserMenu&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Social Links (optional)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 Schritt 1: MobileMenu.jsx ersetzen&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wir ersetzen deinen bisherigen Dummy‑Button durch einen echten Offcanvas‑Trigger.&lt;/span&gt;&lt;/p&gt;&lt;h2&gt;✅ &lt;code&gt;src/components/header/MobileMenu.jsx&lt;/code&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { useState } from &quot;react&quot;;&lt;br/&gt;import Offcanvas from &quot;react-bootstrap/Offcanvas&quot;;&lt;br/&gt;import Navigation from &quot;./Navigation&quot;;&lt;br/&gt;import RoleNavigation from &quot;./RoleNavigation&quot;;&lt;br/&gt;import UserMenu from &quot;./UserMenu&quot;;&lt;br/&gt;&lt;br/&gt;export default function MobileMenu({ role, user }) {&lt;br/&gt;  const [show, setShow] = useState(false);&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;&amp;gt;&lt;br/&gt;      {/* Hamburger Button */}&lt;br/&gt;      &amp;lt;button&lt;br/&gt;        className=&quot;btn btn-outline-secondary d-md-none&quot;&lt;br/&gt;        onClick={() =&amp;gt; setShow(true)}&lt;br/&gt;      &amp;gt;&lt;br/&gt;        ☰&lt;br/&gt;      &amp;lt;/button&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* Offcanvas Menü */}&lt;br/&gt;      &amp;lt;Offcanvas show={show} onHide={() =&amp;gt; setShow(false)} placement=&quot;start&quot;&amp;gt;&lt;br/&gt;        &amp;lt;Offcanvas.Header closeButton&amp;gt;&lt;br/&gt;          &amp;lt;Offcanvas.Title&amp;gt;Menü&amp;lt;/Offcanvas.Title&amp;gt;&lt;br/&gt;        &amp;lt;/Offcanvas.Header&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;Offcanvas.Body&amp;gt;&lt;br/&gt;          &amp;lt;div className=&quot;mb-4&quot;&amp;gt;&lt;br/&gt;            &amp;lt;Navigation mobile /&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;          &amp;lt;div className=&quot;mb-4&quot;&amp;gt;&lt;br/&gt;            &amp;lt;RoleNavigation role={role} mobile /&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;          &amp;lt;div className=&quot;mt-5&quot;&amp;gt;&lt;br/&gt;            &amp;lt;UserMenu user={user} mobile /&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        &amp;lt;/Offcanvas.Body&amp;gt;&lt;br/&gt;      &amp;lt;/Offcanvas&amp;gt;&lt;br/&gt;    &amp;lt;/&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 Schritt 2: Header.jsx anpassen&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wir müssen MobileMenu einbinden und Desktop‑Navigation ausblenden.&lt;/span&gt;&lt;/p&gt;&lt;h2&gt;✅ &lt;code&gt;Header.jsx&lt;/code&gt; aktualisieren&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import Logo from &quot;./Logo&quot;;&lt;br/&gt;import Navigation from &quot;./Navigation&quot;;&lt;br/&gt;import SearchBar from &quot;./SearchBar&quot;;&lt;br/&gt;import Notifications from &quot;./Notifications&quot;;&lt;br/&gt;import UserMenu from &quot;./UserMenu&quot;;&lt;br/&gt;import RoleNavigation from &quot;./RoleNavigation&quot;;&lt;br/&gt;import MobileMenu from &quot;./MobileMenu&quot;;&lt;br/&gt;&lt;br/&gt;export default function Header({ role, user }) {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;header className=&quot;p-3 bg-light border-bottom&quot;&amp;gt;&lt;br/&gt;      &amp;lt;div className=&quot;container d-flex align-items-center justify-content-between&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;Logo /&amp;gt;&lt;br/&gt;&lt;br/&gt;        {/* Desktop Navigation */}&lt;br/&gt;        &amp;lt;div className=&quot;d-none d-md-flex align-items-center&quot;&amp;gt;&lt;br/&gt;          &amp;lt;Navigation /&amp;gt;&lt;br/&gt;          &amp;lt;RoleNavigation role={role} /&amp;gt;&lt;br/&gt;          &amp;lt;SearchBar /&amp;gt;&lt;br/&gt;          &amp;lt;Notifications /&amp;gt;&lt;br/&gt;          &amp;lt;UserMenu user={user} /&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        {/* Mobile Navigation */}&lt;br/&gt;        &amp;lt;MobileMenu role={role} user={user} /&amp;gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;    &amp;lt;/header&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 Schritt 3: Navigation.jsx für Mobile anpassen&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wir machen Navigation flexibel für Desktop &amp;amp; Mobile.&lt;/span&gt;&lt;/p&gt;&lt;h2&gt;✅ &lt;code&gt;Navigation.jsx&lt;/code&gt; aktualisieren&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;export default function Navigation({ mobile = false }) {&lt;br/&gt;  const linkClass = mobile&lt;br/&gt;    ? &quot;d-block mb-3 fs-5&quot;&lt;br/&gt;    : &quot;me-3&quot;;&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;nav&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/&quot; className={linkClass}&amp;gt;Home&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/search&quot; className={linkClass}&amp;gt;Suche&amp;lt;/a&amp;gt;&lt;br/&gt;    &amp;lt;/nav&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 Schritt 4: RoleNavigation für Mobile anpassen&lt;/h1&gt;&lt;h2&gt;Beispiel: &lt;code&gt;GuestNav.jsx&lt;/code&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;export default function GuestNav({ mobile = false }) {&lt;br/&gt;  const linkClass = mobile&lt;br/&gt;    ? &quot;d-block mb-3 fs-5&quot;&lt;br/&gt;    : &quot;me-3&quot;;&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;nav&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/login&quot; className={linkClass}&amp;gt;Login&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/register&quot; className={linkClass}&amp;gt;Registrieren&amp;lt;/a&amp;gt;&lt;br/&gt;    &amp;lt;/nav&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 Das gleiche Prinzip für:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;GesuchterNav.jsx&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;VermieterNav.jsx&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;AdminNav.jsx&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 Schritt 5: UserMenu für Mobile anpassen&lt;/h1&gt;&lt;h2&gt;&lt;code&gt;UserMenu.jsx&lt;/code&gt; aktualisieren&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;export default function UserMenu({ user, mobile = false }) {&lt;br/&gt;  if (!user) {&lt;br/&gt;    return (&lt;br/&gt;      &amp;lt;a&lt;br/&gt;        href=&quot;/login&quot;&lt;br/&gt;        className={mobile ? &quot;btn btn-primary w-100&quot; : &quot;btn btn-outline-primary&quot;}&lt;br/&gt;      &amp;gt;&lt;br/&gt;        Login&lt;br/&gt;      &amp;lt;/a&amp;gt;&lt;br/&gt;    );&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  if (mobile) {&lt;br/&gt;    return (&lt;br/&gt;      &amp;lt;div&amp;gt;&lt;br/&gt;        &amp;lt;p className=&quot;fw-bold mb-2&quot;&amp;gt;{user.email}&amp;lt;/p&amp;gt;&lt;br/&gt;        &amp;lt;a href=&quot;/profile&quot; className=&quot;d-block mb-3&quot;&amp;gt;Profil&amp;lt;/a&amp;gt;&lt;br/&gt;        &amp;lt;a href=&quot;/logout&quot; className=&quot;btn btn-danger w-100&quot;&amp;gt;Logout&amp;lt;/a&amp;gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;    );&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;dropdown&quot;&amp;gt;&lt;br/&gt;      &amp;lt;button className=&quot;btn btn-secondary dropdown-toggle&quot; data-bs-toggle=&quot;dropdown&quot;&amp;gt;&lt;br/&gt;        {user.email}&lt;br/&gt;      &amp;lt;/button&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;ul className=&quot;dropdown-menu&quot;&amp;gt;&lt;br/&gt;        &amp;lt;li&amp;gt;&amp;lt;a className=&quot;dropdown-item&quot; href=&quot;/profile&quot;&amp;gt;Profil&amp;lt;/a&amp;gt;&amp;lt;/li&amp;gt;&lt;br/&gt;        &amp;lt;li&amp;gt;&amp;lt;a className=&quot;dropdown-item&quot; href=&quot;/logout&quot;&amp;gt;Logout&amp;lt;/a&amp;gt;&amp;lt;/li&amp;gt;&lt;br/&gt;      &amp;lt;/ul&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 &lt;strong&gt;FERTIG! Deine Mobile Navigation ist jetzt:&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ vollständig responsive&lt;br/&gt;✔ mit Offcanvas‑Menü&lt;br/&gt;✔ lädt Navigation + Rollen‑Navigation + UserMenu&lt;br/&gt;✔ perfekt integriert in deinen Header&lt;br/&gt;✔ sauber modular aufgebaut&lt;br/&gt;✔ Bootstrap‑ready&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Was möchtest du als Nächstes?&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Hier sind sinnvolle nächste Schritte:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Logout‑Funktion richtig einbauen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Header dynamisch mit AuthContext verbinden&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;gesuchter/vermieter/admin Seiten mit Inhalt füllen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Design verbessern (Icons, Farben, Layout)&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, womit wir weitermachen.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="3620" width="660" x="-8070" y="-9700" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-17" parent="1" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=173;height=30;strokeColor=#1E90FF;strokeWidth=4;" value="AppRouter.jsx" vertex="1">
          <mxGeometry height="7160" width="6300" x="-80" y="-680" as="geometry" />
