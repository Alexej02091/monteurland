        <mxCell id="pQg1HVivcMeYRdmA5alk-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;ZJ5zaT2FAWKfrjvJHHfuf-author ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div id=&quot;ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Perfekt — &lt;strong&gt;jetzt sehe ich ganz genau, warum dein komplettes Layout zentriert ist.&lt;/strong&gt;  &lt;br/&gt;Der Fehler steckt &lt;strong&gt;hier&lt;/strong&gt;:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;#root {&lt;br/&gt;  width: 1126px;&lt;br/&gt;  max-width: 100%;&lt;br/&gt;  margin: 0 auto;&lt;br/&gt;  text-align: center;&lt;br/&gt;  border-inline: 1px solid var(--border);&lt;br/&gt;  min-height: 100svh;&lt;br/&gt;  display: flex;&lt;br/&gt;  flex-direction: column;&lt;br/&gt;  box-sizing: border-box;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ist der &lt;strong&gt;entscheidende Grund&lt;/strong&gt;, warum dein Header NICHT wie beim Original über die volle Breite geht.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🚨 &lt;strong&gt;Warum das dein Layout zerstört&lt;/strong&gt;&lt;/h1&gt;&lt;h3&gt;1. &lt;code&gt;width: 1126px;&lt;/code&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;→ Deine komplette Seite wird künstlich auf &lt;strong&gt;1126px Breite begrenzt&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;2. &lt;code&gt;margin: 0 auto;&lt;/code&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;→ Dadurch wird die gesamte Seite &lt;strong&gt;zentriert&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;3. &lt;code&gt;text-align: center;&lt;/code&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;→ Alles, was kein Block‑Element ist, wird zusätzlich &lt;strong&gt;mittig ausgerichtet&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;4. &lt;code&gt;display: flex; flex-direction: column;&lt;/code&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;→ Das ist nicht schlimm, aber unnötig.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;So sieht es bei dir aus&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;|-------------------- Bildschirm --------------------|&lt;br/&gt;|             [ 1126px breite Box ]                 |&lt;br/&gt;|             [   alles zentriert   ]               |&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;So sieht es beim Original aus&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;|-------------------- Bildschirm --------------------|&lt;br/&gt;| Logo | Menü | Login                               |&lt;br/&gt;|----------------------------------------------------|&lt;br/&gt;| Suchbox über volle Breite                          |&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;Lösung: #root komplett zurücksetzen&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ersetze deinen gesamten &lt;code&gt;#root&lt;/code&gt;‑Block durch:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;#root {&lt;br/&gt;  margin: 0;&lt;br/&gt;  padding: 0;&lt;br/&gt;  min-height: 100vh;&lt;br/&gt;  box-sizing: border-box;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Oder wenn du es ganz sauber willst:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;#root {&lt;br/&gt;  margin: 0;&lt;br/&gt;  padding: 0;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;💥 Ergebnis nach der Änderung&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Header geht &lt;strong&gt;über die volle Breite&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Suchbereich geht &lt;strong&gt;über die volle Breite&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Nichts ist mehr zentriert&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Dein Layout verhält sich wie beim Original&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📌 Empfehlung&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Die gesamte CSS, die du gepostet hast, stammt aus der &lt;strong&gt;Vite‑Demo&lt;/strong&gt;.&lt;br/&gt;Sie ist &lt;strong&gt;nicht&lt;/strong&gt; für echte Websites gedacht.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 &lt;strong&gt;Lösch am besten die komplette index.css und App.css&lt;/strong&gt;  &lt;br/&gt;und fang mit einer sauberen Basis an.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich kann dir sofort eine perfekte, minimalistische Basis‑CSS geben, wenn du willst.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Willst du, dass ich dir eine saubere Grundstruktur + CSS erstelle, die exakt wie das Original funktioniert?&lt;/h1&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1680" width="950" x="-2670" y="-200" as="geometry" />
        </mxCell>
        <mxCell id="pQg1HVivcMeYRdmA5alk-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;ZJ5zaT2FAWKfrjvJHHfuf-author ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div id=&quot;ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot;&gt;&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;Pwsnk94yxaThtoPkgZuhQ-author Pwsnk94yxaThtoPkgZuhQ-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div&gt;&lt;div id=&quot;Pwsnk94yxaThtoPkgZuhQ-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — wenn sich &lt;strong&gt;gar nichts geändert hat&lt;/strong&gt;, obwohl du &lt;code&gt;#root&lt;/code&gt; angepasst hast, dann gibt es nur &lt;strong&gt;3 mögliche Ursachen&lt;/strong&gt;.&lt;br/&gt;Ich gehe sie mit dir durch, und wir finden das Problem sofort.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;Ursache 1: Deine App steckt in einem zentrierenden Wrapper&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bitte prüfe deine &lt;code&gt;index.html&lt;/code&gt;:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;❌ Wenn du sowas hast:&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;html&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;div id=&quot;center&quot;&amp;gt;&lt;br/&gt;  &amp;lt;div id=&quot;root&quot;&amp;gt;&amp;lt;/div&amp;gt;&lt;br/&gt;&amp;lt;/div&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;oder&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;html&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;div class=&quot;container&quot;&amp;gt;&lt;br/&gt;  &amp;lt;div id=&quot;root&quot;&amp;gt;&amp;lt;/div&amp;gt;&lt;br/&gt;&amp;lt;/div&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ Dann wird &lt;strong&gt;alles&lt;/strong&gt; zentriert, egal was du in CSS machst.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;✔ So muss es aussehen:&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;html&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;div id=&quot;root&quot;&amp;gt;&amp;lt;/div&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Nur das. Keine Wrapper, keine Container.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;Ursache 2: Dein App.jsx zentriert alles&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bitte prüfe deine &lt;code&gt;App.jsx&lt;/code&gt;.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du sowas hast:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;div id=&quot;center&quot;&amp;gt;&lt;br/&gt;  &amp;lt;Header /&amp;gt;&lt;br/&gt;  &amp;lt;SearchBar /&amp;gt;&lt;br/&gt;&amp;lt;/div&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;oder&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;div className=&quot;container&quot;&amp;gt;&lt;br/&gt;  &amp;lt;Header /&amp;gt;&lt;br/&gt;&amp;lt;/div&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ Dann wird der komplette Inhalt zentriert.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;✔ So muss es aussehen:&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;&amp;gt;&lt;br/&gt;  &amp;lt;Header /&amp;gt;&lt;br/&gt;  &amp;lt;main&amp;gt;&lt;br/&gt;    {/* Inhalt */}&lt;br/&gt;  &amp;lt;/main&amp;gt;&lt;br/&gt;&amp;lt;/&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;Ursache 3: Deine index.css überschreibt Bootstrap&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich sehe in deiner index.css:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;#root {&lt;br/&gt;  width: 1126px;&lt;br/&gt;  margin: 0 auto;&lt;br/&gt;  text-align: center;&lt;br/&gt;  display: flex;&lt;br/&gt;  flex-direction: column;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du das &lt;strong&gt;geändert hast&lt;/strong&gt;, aber es wirkt nicht, dann gibt es zwei Möglichkeiten:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;❌ 1. Du hast index.css nicht gespeichert&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;(ja, passiert oft)&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;❌ 2. Du hast index.css an der falschen Stelle geändert&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;(z. B. in einem anderen Ordner)&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;❌ 3. Du hast noch eine zweite CSS-Datei, die #root überschreibt&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;(z. B. App.css, global.css, styles.css)&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔥 &lt;strong&gt;Bitte sende mir deine App.jsx&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit kann ich dir in 10 Sekunden sagen, wo die Zentrierung herkommt.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 Zwischenlösung (funktioniert immer)&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, dass der Header &lt;strong&gt;sofort&lt;/strong&gt; volle Breite bekommt, füge in &lt;code&gt;index.css&lt;/code&gt; ganz unten hinzu:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;#root {&lt;br/&gt;  width: 100% !important;&lt;br/&gt;  max-width: 100% !important;&lt;br/&gt;  margin: 0 !important;&lt;br/&gt;  text-align: left !important;&lt;br/&gt;  display: block !important;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ Das überschreibt ALLES, was vorher zentriert hat.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn danach immer noch alles mittig ist, dann liegt es &lt;strong&gt;nicht an CSS&lt;/strong&gt;, sondern an deinem JSX‑Layout.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Schick mir bitte deine &lt;code&gt;App.jsx&lt;/code&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Dann löse ich das Problem endgültig.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;min-h-[calc(100%-56px)] flex shrink-0 flex-col&quot; data-testid=&quot;highlighted-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; id=&quot;JEuoHQk87TgH7YeZAofFF-user-message&quot; aria-labelledby=&quot;JEuoHQk87TgH7YeZAofFF-user-message&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div class=&quot;flex w-full flex-col gap-1&quot;&gt;&lt;div class=&quot;font-ligatures-none relative h-fit max-w-user-text-message whitespace-pre-wrap break-words px-4 py-2.5 squircle-16 bg-accent-250/60 dark:bg-accent-200 text-base self-end&quot; data-content=&quot;user-message&quot;&gt;&amp;lt;!doctype html&amp;gt;&lt;br/&gt;&amp;lt;html lang=&quot;en&quot;&amp;gt;&lt;br/&gt;  &amp;lt;head&amp;gt;&lt;br/&gt;    &amp;lt;meta charset=&quot;UTF-8&quot; /&amp;gt;&lt;br/&gt;    &amp;lt;link rel=&quot;icon&quot; type=&quot;image/svg+xml&quot; href=&quot;/favicon.svg&quot; /&amp;gt;&lt;br/&gt;    &amp;lt;meta name=&quot;viewport&quot; content=&quot;width=device-width, initial-scale=1.0&quot; /&amp;gt;&lt;br/&gt;    &amp;lt;title&amp;gt;my-react-app&amp;lt;/title&amp;gt;&lt;br/&gt;  &amp;lt;/head&amp;gt;&lt;br/&gt;  &amp;lt;body&amp;gt;&lt;br/&gt;    &amp;lt;div id=&quot;root&quot;&amp;gt;&amp;lt;/div&amp;gt;&lt;br/&gt;    &amp;lt;script type=&quot;module&quot; src=&quot;/src/main.jsx&quot;&amp;gt;&amp;lt;/script&amp;gt;&lt;br/&gt;  &amp;lt;/body&amp;gt;&lt;br/&gt;&amp;lt;/html&amp;gt;&lt;br/&gt;&lt;br/&gt;index.html&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;3V7zEK697UsKm6oXCNYnE-author 3V7zEK697UsKm6oXCNYnE-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div&gt;&lt;/div&gt;&lt;div class=&quot;space-y-3 mt-3&quot;&gt;&lt;div id=&quot;3V7zEK697UsKm6oXCNYnE-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Danke — deine &lt;strong&gt;index.html ist perfekt&lt;/strong&gt;.&lt;br/&gt;Das bedeutet: &lt;strong&gt;Der Fehler liegt definitiv NICHT in index.html.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit bleibt nur eine Ursache übrig — und jetzt kommt der entscheidende Punkt:&lt;/span&gt;&lt;/p&gt;&lt;h1&gt;🚨 &lt;strong&gt;Der Grund, warum ALLES bei dir zentriert bleibt:&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 &lt;strong&gt;Dein &lt;/strong&gt;&lt;code&gt;#root&lt;/code&gt;&lt;strong&gt; wird weiterhin durch deine index.css begrenzt und zentriert.&lt;/strong&gt;  &lt;br/&gt;Auch wenn du glaubst, du hast es geändert — der Browser lädt immer noch die alte Version.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Und ich sehe in deiner index.css ganz klar:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;#root {&lt;br/&gt;  width: 1126px;&lt;br/&gt;  max-width: 100%;&lt;br/&gt;  margin: 0 auto;&lt;br/&gt;  text-align: center;&lt;br/&gt;  border-inline: 1px solid var(--border);&lt;br/&gt;  min-height: 100svh;&lt;br/&gt;  display: flex;&lt;br/&gt;  flex-direction: column;&lt;br/&gt;  box-sizing: border-box;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das &lt;strong&gt;zentriert deine komplette Seite&lt;/strong&gt; und begrenzt sie auf &lt;strong&gt;1126px&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Solange dieser Block existiert, wird dein Header &lt;strong&gt;niemals&lt;/strong&gt; volle Breite haben.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;Lösung (100% sicher): index.css korrigieren&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bitte ersetze den gesamten &lt;code&gt;#root&lt;/code&gt;‑Block durch:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;#root {&lt;br/&gt;  margin: 0;&lt;br/&gt;  padding: 0;&lt;br/&gt;  width: 100%;&lt;br/&gt;  max-width: 100%;&lt;br/&gt;  text-align: left;&lt;br/&gt;  display: block;&lt;br/&gt;  box-sizing: border-box;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Oder noch besser — komplett löschen:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;#root {}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔥 &lt;strong&gt;Wenn es danach IMMER NOCH zentriert ist:&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Dann liegt es daran, dass &lt;strong&gt;Vite den alten CSS‑Cache hält&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;&lt;h2&gt;✔ Lösung: Dev‑Server neu starten&lt;/h2&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Terminal schließen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;npm run dev&lt;/code&gt; neu starten&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Browser neu laden (STRG + F5)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧪 &lt;strong&gt;Test: Funktioniert es?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Um sicherzugehen, füge GANZ UNTEN in index.css hinzu:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;#root {&lt;br/&gt;  background: red !important;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn der Hintergrund &lt;strong&gt;nicht rot wird&lt;/strong&gt;, dann:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ du bearbeitest die &lt;strong&gt;falsche Datei&lt;/strong&gt;  &lt;br/&gt;➡ oder Vite lädt die Datei nicht&lt;br/&gt;➡ oder du hast mehrere CSS‑Dateien&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn der Hintergrund rot wird:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ CSS wird geladen&lt;br/&gt;➡ dann ist das Zentrierproblem lösbar&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir bitte:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 Wird der Hintergrund rot?&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn ja, lösen wir es sofort.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="3490" width="950" x="-2670" y="1520" as="geometry" />
        </mxCell>
        <mxCell id="pQg1HVivcMeYRdmA5alk-7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;ZJ5zaT2FAWKfrjvJHHfuf-author ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div id=&quot;ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;a, wir können den kompletten Header &lt;strong&gt;mit React‑Bootstrap&lt;/strong&gt; nachbauen — und zwar so, dass er &lt;strong&gt;wie das Original aussieht&lt;/strong&gt;, aber mit sauberer, moderner Struktur.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich baue dir jetzt:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Top‑Bar&lt;/strong&gt; (Suchender / Vermieter + Flagge)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Haupt‑Navigation&lt;/strong&gt; (Logo + Menü)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Mobile Menü&lt;/strong&gt; (Burger + Slide‑Down)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles mit &lt;strong&gt;React‑Bootstrap&lt;/strong&gt; + Icons.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;1. Installation (falls noch nicht gemacht)&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;bash&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;npm install react-bootstrap bootstrap react-bootstrap-icons&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;In &lt;code&gt;main.jsx&lt;/code&gt;:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import &quot;bootstrap/dist/css/bootstrap.min.css&quot;;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;2. React‑Bootstrap Header (Original‑Look)&lt;/strong&gt;&lt;/h1&gt;&lt;h2&gt;📁 &lt;code&gt;Header.jsx&lt;/code&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { useState } from &quot;react&quot;;&lt;br/&gt;import { Container, Row, Col, Nav, Navbar, Image } from &quot;react-bootstrap&quot;;&lt;br/&gt;import { List } from &quot;react-bootstrap-icons&quot;;&lt;br/&gt;import &quot;./header.css&quot;;&lt;br/&gt;&lt;br/&gt;export default function Header() {&lt;br/&gt;  const [mobileOpen, setMobileOpen] = useState(false);&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;header className=&quot;mmz-header&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* Top Bar */}&lt;br/&gt;      &amp;lt;div className=&quot;mmz-topbar&quot;&amp;gt;&lt;br/&gt;        &amp;lt;Container&amp;gt;&lt;br/&gt;          &amp;lt;Row className=&quot;align-items-center&quot;&amp;gt;&lt;br/&gt;            &amp;lt;Col className=&quot;d-flex gap-3&quot;&amp;gt;&lt;br/&gt;              &amp;lt;span className=&quot;mmz-top-link active&quot;&amp;gt;Suchender&amp;lt;/span&amp;gt;&lt;br/&gt;              &amp;lt;span className=&quot;mmz-top-link&quot;&amp;gt;Vermieter&amp;lt;/span&amp;gt;&lt;br/&gt;            &amp;lt;/Col&amp;gt;&lt;br/&gt;&lt;br/&gt;            &amp;lt;Col className=&quot;text-end&quot;&amp;gt;&lt;br/&gt;              &amp;lt;div className=&quot;mmz-flag flag-de&quot;&amp;gt;&amp;lt;/div&amp;gt;&lt;br/&gt;            &amp;lt;/Col&amp;gt;&lt;br/&gt;          &amp;lt;/Row&amp;gt;&lt;br/&gt;        &amp;lt;/Container&amp;gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* Main Navigation */}&lt;br/&gt;      &amp;lt;Navbar expand=&quot;lg&quot; className=&quot;mmz-navbar&quot;&amp;gt;&lt;br/&gt;        &amp;lt;Container&amp;gt;&lt;br/&gt;&lt;br/&gt;          {/* Logo */}&lt;br/&gt;          &amp;lt;Navbar.Brand href=&quot;/&quot; className=&quot;d-flex align-items-center gap-2&quot;&amp;gt;&lt;br/&gt;            &amp;lt;Image src=&quot;/logo-icon.png&quot; height={32} /&amp;gt;&lt;br/&gt;            &amp;lt;Image src=&quot;/logo-text.svg&quot; height={24} /&amp;gt;&lt;br/&gt;          &amp;lt;/Navbar.Brand&amp;gt;&lt;br/&gt;&lt;br/&gt;          {/* Burger */}&lt;br/&gt;          &amp;lt;List&lt;br/&gt;            size={32}&lt;br/&gt;            className=&quot;mmz-burger d-lg-none&quot;&lt;br/&gt;            onClick={() =&amp;gt; setMobileOpen(!mobileOpen)}&lt;br/&gt;          /&amp;gt;&lt;br/&gt;&lt;br/&gt;          {/* Desktop Menu */}&lt;br/&gt;          &amp;lt;Navbar.Collapse className=&quot;justify-content-end d-none d-lg-flex&quot;&amp;gt;&lt;br/&gt;            &amp;lt;Nav className=&quot;gap-3&quot;&amp;gt;&lt;br/&gt;              &amp;lt;Nav.Link href=&quot;/vorteile&quot; className=&quot;mmz-item&quot;&amp;gt;Vorteile&amp;lt;/Nav.Link&amp;gt;&lt;br/&gt;              &amp;lt;Nav.Link href=&quot;/news&quot; className=&quot;mmz-item&quot;&amp;gt;Nachricht&amp;lt;/Nav.Link&amp;gt;&lt;br/&gt;              &amp;lt;Nav.Link href=&quot;/faq-suchende&quot; className=&quot;mmz-item&quot;&amp;gt;Häufig gestellte Fragen&amp;lt;/Nav.Link&amp;gt;&lt;br/&gt;              &amp;lt;Nav.Link href=&quot;https://shop.mein-monteurzimmer.de/&quot; target=&quot;_blank&quot; className=&quot;mmz-item&quot;&amp;gt;Geschäft&amp;lt;/Nav.Link&amp;gt;&lt;br/&gt;            &amp;lt;/Nav&amp;gt;&lt;br/&gt;          &amp;lt;/Navbar.Collapse&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;/Container&amp;gt;&lt;br/&gt;      &amp;lt;/Navbar&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* Mobile Menu */}&lt;br/&gt;      {mobileOpen &amp;amp;&amp;amp; (&lt;br/&gt;        &amp;lt;div className=&quot;mmz-mobile d-lg-none&quot;&amp;gt;&lt;br/&gt;          &amp;lt;Container&amp;gt;&lt;br/&gt;            &amp;lt;div className=&quot;d-flex gap-3 mb-3&quot;&amp;gt;&lt;br/&gt;              &amp;lt;span className=&quot;mmz-top-link active&quot;&amp;gt;Suchender&amp;lt;/span&amp;gt;&lt;br/&gt;              &amp;lt;span className=&quot;mmz-top-link&quot;&amp;gt;Vermieter&amp;lt;/span&amp;gt;&lt;br/&gt;            &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;            &amp;lt;Nav className=&quot;flex-column gap-2&quot;&amp;gt;&lt;br/&gt;              &amp;lt;Nav.Link href=&quot;/&quot; className=&quot;mmz-item active&quot;&amp;gt;Suche&amp;lt;/Nav.Link&amp;gt;&lt;br/&gt;              &amp;lt;Nav.Link href=&quot;/vorteile&quot; className=&quot;mmz-item&quot;&amp;gt;Vorteile&amp;lt;/Nav.Link&amp;gt;&lt;br/&gt;              &amp;lt;Nav.Link href=&quot;/news&quot; className=&quot;mmz-item&quot;&amp;gt;Nachricht&amp;lt;/Nav.Link&amp;gt;&lt;br/&gt;              &amp;lt;Nav.Link href=&quot;/faq-suchende&quot; className=&quot;mmz-item&quot;&amp;gt;Häufig gestellte Fragen&amp;lt;/Nav.Link&amp;gt;&lt;br/&gt;              &amp;lt;Nav.Link href=&quot;https://shop.mein-monteurzimmer.de/&quot; target=&quot;_blank&quot; className=&quot;mmz-item&quot;&amp;gt;Geschäft&amp;lt;/Nav.Link&amp;gt;&lt;br/&gt;            &amp;lt;/Nav&amp;gt;&lt;br/&gt;          &amp;lt;/Container&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;      )}&lt;br/&gt;&lt;br/&gt;    &amp;lt;/header&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎨 &lt;strong&gt;3. CSS für Original‑Look&lt;/strong&gt;&lt;/h1&gt;&lt;h2&gt;📁 &lt;code&gt;header.css&lt;/code&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;.mmz-header {&lt;br/&gt;  width: 100%;&lt;br/&gt;  background: #fff;&lt;br/&gt;  border-bottom: 1px solid #e5e5e5;&lt;br/&gt;  font-family: system-ui, sans-serif;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Top Bar */&lt;br/&gt;.mmz-topbar {&lt;br/&gt;  background: #f7f7f7;&lt;br/&gt;  border-bottom: 1px solid #e5e5e5;&lt;br/&gt;  padding: 6px 0;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;.mmz-top-link {&lt;br/&gt;  font-size: 14px;&lt;br/&gt;  color: #666;&lt;br/&gt;  cursor: pointer;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;.mmz-top-link.active {&lt;br/&gt;  font-weight: 600;&lt;br/&gt;  color: #000;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Flag */&lt;br/&gt;.flag-de {&lt;br/&gt;  width: 22px;&lt;br/&gt;  height: 16px;&lt;br/&gt;  background-image: url(&quot;/flag-de.png&quot;);&lt;br/&gt;  background-size: cover;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Main Nav */&lt;br/&gt;.mmz-navbar {&lt;br/&gt;  padding: 14px 0;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;.mmz-item {&lt;br/&gt;  font-size: 15px;&lt;br/&gt;  color: #333 !important;&lt;br/&gt;  padding: 6px 10px;&lt;br/&gt;  border-radius: 6px;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;.mmz-item:hover {&lt;br/&gt;  background: #f2f2f2;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Burger */&lt;br/&gt;.mmz-burger {&lt;br/&gt;  cursor: pointer;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Mobile Menu */&lt;br/&gt;.mmz-mobile {&lt;br/&gt;  background: #fff;&lt;br/&gt;  border-top: 1px solid #e5e5e5;&lt;br/&gt;  padding: 20px 0;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 Ergebnis&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du bekommst:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;React‑Bootstrap Header&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Top‑Bar wie im Original&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Logo + Navigation wie im Original&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Mobile Menü wie im Original&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Saubere Struktur&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Bootstrap‑Grid für perfekte Ausrichtung&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Was möchtest du als Nächstes?&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich kann dir:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;🔹 Die Suchbox unter dem Header (1:1 wie Original) bauen&lt;/h3&gt;&lt;h3&gt;🔹 Die komplette Startseite nachbauen&lt;/h3&gt;&lt;h3&gt;🔹 Die mobile Animation verbessern&lt;/h3&gt;&lt;h3&gt;🔹 Flaggen‑Dropdown interaktiv machen&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, was du brauchst.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="3170" width="950" x="-2680" y="5080" as="geometry" />
        </mxCell>
        <mxCell id="pQg1HVivcMeYRdmA5alk-8" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;ZJ5zaT2FAWKfrjvJHHfuf-author ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div id=&quot;ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — jetzt weiß ich genau, was du meinst.&lt;br/&gt;Auf &lt;strong&gt;mein‑monteurzimmer.de&lt;/strong&gt; ist die Top‑Bar so aufgebaut:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Rechts&lt;/strong&gt;: „Suchender“ und „Vermieter“&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der aktive Tab hat &lt;strong&gt;gelbe Hintergrundfarbe&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Links ist &lt;strong&gt;nichts&lt;/strong&gt;, alles sitzt rechtsbündig&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wir bauen das jetzt &lt;strong&gt;mit React‑Bootstrap&lt;/strong&gt; exakt so nach.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;Top‑Bar wie im Original (rechtsbündig + gelb aktiv)&lt;/strong&gt;&lt;/h1&gt;&lt;h2&gt;📁 &lt;code&gt;Header.jsx&lt;/code&gt; (nur der Top‑Bar‑Teil)&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { Container } from &quot;react-bootstrap&quot;;&lt;br/&gt;import &quot;./header.css&quot;;&lt;br/&gt;&lt;br/&gt;export default function Header() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;header className=&quot;mmz-header&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* TOP BAR */}&lt;br/&gt;      &amp;lt;div className=&quot;mmz-topbar&quot;&amp;gt;&lt;br/&gt;        &amp;lt;Container className=&quot;d-flex justify-content-end align-items-center gap-3&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;          &amp;lt;span className=&quot;mmz-top-link active&quot;&amp;gt;Suchender&amp;lt;/span&amp;gt;&lt;br/&gt;          &amp;lt;span className=&quot;mmz-top-link&quot;&amp;gt;Vermieter&amp;lt;/span&amp;gt;&lt;br/&gt;&lt;br/&gt;          &amp;lt;div className=&quot;mmz-flag flag-de&quot;&amp;gt;&amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;/Container&amp;gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* ... Rest vom Header */}&lt;br/&gt;    &amp;lt;/header&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎨 &lt;strong&gt;CSS für Top‑Bar (gelb + rechtsbündig)&lt;/strong&gt;&lt;/h1&gt;&lt;h2&gt;📁 &lt;code&gt;header.css&lt;/code&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;/* Top Bar */&lt;br/&gt;.mmz-topbar {&lt;br/&gt;  background: #f7f7f7;&lt;br/&gt;  border-bottom: 1px solid #e5e5e5;&lt;br/&gt;  padding: 6px 0;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Tabs rechts */&lt;br/&gt;.mmz-top-link {&lt;br/&gt;  font-size: 14px;&lt;br/&gt;  padding: 4px 10px;&lt;br/&gt;  border-radius: 4px;&lt;br/&gt;  cursor: pointer;&lt;br/&gt;  color: #333;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Aktiver Tab = GELB wie Original */&lt;br/&gt;.mmz-top-link.active {&lt;br/&gt;  background: #ffd200; /* Original Gelb */&lt;br/&gt;  font-weight: 600;&lt;br/&gt;  color: #000;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Flagge */&lt;br/&gt;.flag-de {&lt;br/&gt;  width: 22px;&lt;br/&gt;  height: 16px;&lt;br/&gt;  background-image: url(&quot;/flag-de.png&quot;);&lt;br/&gt;  background-size: cover;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 Ergebnis&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;„Suchender“ und „Vermieter“ stehen &lt;strong&gt;rechts&lt;/strong&gt;, wie beim Original&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der aktive Tab („Suchender“) ist &lt;strong&gt;gelb hinterlegt&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Flagge sitzt ebenfalls rechts&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles mit React‑Bootstrap kompatibel&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Als Nächstes können wir:&lt;/h1&gt;&lt;h3&gt;🔹 Die Hauptnavigation darunter exakt nachbauen&lt;/h3&gt;&lt;h3&gt;🔹 Die Suchbox unter dem Header 1:1 nachbauen&lt;/h3&gt;&lt;h3&gt;🔹 Mobile Menü wie im Original umsetzen&lt;/h3&gt;&lt;h3&gt;🔹 Die gelbe Farbe dynamisch machen (per State)&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir, welchen Teil wir als Nächstes bauen.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1560" width="950" x="-2670" y="8290" as="geometry" />
        </mxCell>
        <mxCell id="pQg1HVivcMeYRdmA5alk-9" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;ZJ5zaT2FAWKfrjvJHHfuf-author ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div id=&quot;ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — jetzt bauen wir die &lt;strong&gt;Top‑Navigation „Suchender / Vermieter“ so nach&lt;/strong&gt;, dass:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;beide Tabs &lt;strong&gt;direkt nebeneinander&lt;/strong&gt; stehen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;sie &lt;strong&gt;einen gemeinsamen Rahmen&lt;/strong&gt; haben&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der aktive Tab &lt;strong&gt;gelb hinterlegt&lt;/strong&gt; ist&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der Rahmen &lt;strong&gt;durchgehend&lt;/strong&gt; ist (wie beim Original)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;React‑Bootstrap verwendet wird&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der aktive Zustand per React‑State gesteuert wird&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Genau so funktioniert es auf mein‑monteurzimmer.de.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;React‑Bootstrap Version mit gemeinsamem Rahmen + gelbem aktiven Tab&lt;/strong&gt;&lt;/h1&gt;&lt;h2&gt;📁 &lt;code&gt;Header.jsx&lt;/code&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { useState } from &quot;react&quot;;&lt;br/&gt;import { Container } from &quot;react-bootstrap&quot;;&lt;br/&gt;import &quot;./header.css&quot;;&lt;br/&gt;&lt;br/&gt;export default function Header() {&lt;br/&gt;  const [activeTab, setActiveTab] = useState(&quot;suchender&quot;);&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;header className=&quot;mmz-header&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* TOP BAR */}&lt;br/&gt;      &amp;lt;div className=&quot;mmz-topbar&quot;&amp;gt;&lt;br/&gt;        &amp;lt;Container className=&quot;d-flex justify-content-end&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;          &amp;lt;div className=&quot;mmz-switch&quot;&amp;gt;&lt;br/&gt;            &amp;lt;span&lt;br/&gt;              className={&lt;br/&gt;                &quot;mmz-switch-item &quot; +&lt;br/&gt;                (activeTab === &quot;suchender&quot; ? &quot;active&quot; : &quot;&quot;)&lt;br/&gt;              }&lt;br/&gt;              onClick={() =&amp;gt; setActiveTab(&quot;suchender&quot;)}&lt;br/&gt;            &amp;gt;&lt;br/&gt;              Suchender&lt;br/&gt;            &amp;lt;/span&amp;gt;&lt;br/&gt;&lt;br/&gt;            &amp;lt;span&lt;br/&gt;              className={&lt;br/&gt;                &quot;mmz-switch-item &quot; +&lt;br/&gt;                (activeTab === &quot;vermieter&quot; ? &quot;active&quot; : &quot;&quot;)&lt;br/&gt;              }&lt;br/&gt;              onClick={() =&amp;gt; setActiveTab(&quot;vermieter&quot;)}&lt;br/&gt;            &amp;gt;&lt;br/&gt;              Vermieter&lt;br/&gt;            &amp;lt;/span&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;          &amp;lt;div className=&quot;mmz-flag flag-de&quot;&amp;gt;&amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;/Container&amp;gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* ... Rest vom Header */}&lt;br/&gt;    &amp;lt;/header&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎨 &lt;strong&gt;CSS für gemeinsamen Rahmen + gelben aktiven Tab&lt;/strong&gt;&lt;/h1&gt;&lt;h2&gt;📁 &lt;code&gt;header.css&lt;/code&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;/* Top Bar */&lt;br/&gt;.mmz-topbar {&lt;br/&gt;  background: #f7f7f7;&lt;br/&gt;  border-bottom: 1px solid #e5e5e5;&lt;br/&gt;  padding: 6px 0;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* SWITCH BOX (Suchender / Vermieter) */&lt;br/&gt;.mmz-switch {&lt;br/&gt;  display: flex;&lt;br/&gt;  border: 1px solid #dcdcdc;&lt;br/&gt;  border-radius: 6px;&lt;br/&gt;  overflow: hidden;&lt;br/&gt;  margin-right: 16px;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Einzelner Tab */&lt;br/&gt;.mmz-switch-item {&lt;br/&gt;  padding: 6px 14px;&lt;br/&gt;  font-size: 14px;&lt;br/&gt;  cursor: pointer;&lt;br/&gt;  background: #fff;&lt;br/&gt;  color: #333;&lt;br/&gt;  transition: 0.2s;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Aktiver Tab = GELB */&lt;br/&gt;.mmz-switch-item.active {&lt;br/&gt;  background: #ffd200; /* Original Gelb */&lt;br/&gt;  font-weight: 600;&lt;br/&gt;  color: #000;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Flagge */&lt;br/&gt;.flag-de {&lt;br/&gt;  width: 22px;&lt;br/&gt;  height: 16px;&lt;br/&gt;  background-image: url(&quot;/flag-de.png&quot;);&lt;br/&gt;  background-size: cover;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 Ergebnis&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du bekommst jetzt:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Einen gemeinsamen Rahmen&lt;/strong&gt; um beide Tabs&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Tabs direkt nebeneinander&lt;/strong&gt;, ohne Abstand&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Gelber aktiver Tab&lt;/strong&gt;, wie beim Original&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Rechtsbündige Ausrichtung&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;React‑State&lt;/strong&gt;, um den aktiven Tab zu steuern&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;React‑Bootstrap kompatibel&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;So sieht es dann aus:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;[ Suchender | Vermieter ]  🇩🇪&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn „Suchender“ aktiv ist:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;[ SUCHENDER | Vermieter ]  🇩🇪&lt;br/&gt;   gelb&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Willst du, dass wir jetzt:&lt;/h1&gt;&lt;h3&gt;🔹 Die Hauptnavigation darunter (Logo + Menü) exakt nachbauen?&lt;/h3&gt;&lt;h3&gt;🔹 Die Suchbox unter dem Header 1:1 nachbauen?&lt;/h3&gt;&lt;h3&gt;🔹 Mobile Version wie beim Original machen?&lt;/h3&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="2380" width="950" x="-3830" y="-180" as="geometry" />
        </mxCell>
        <mxCell id="pQg1HVivcMeYRdmA5alk-10" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;ZJ5zaT2FAWKfrjvJHHfuf-author ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div id=&quot;ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — hier bekommst du &lt;strong&gt;die komplette, fertige und korrigierte &lt;/strong&gt;&lt;code&gt;header.css&lt;/code&gt;, so dass:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Suchender/Vermieter‑Switch&lt;/strong&gt; und &lt;strong&gt;Navbar&lt;/strong&gt; farblich perfekt zusammenpassen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der aktive Tab &lt;strong&gt;gelb&lt;/strong&gt; ist&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;die gelbe Farbe &lt;strong&gt;bis zur Navbar durchläuft&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;die Navbar &lt;strong&gt;abhängig vom aktiven Tab&lt;/strong&gt; gelb oder weiß ist&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;keine Lücken, keine grauen Ränder mehr&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Diese Version ist &lt;strong&gt;100% funktional&lt;/strong&gt; mit deinem React‑Code.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;FERTIGE &lt;/strong&gt;&lt;code&gt;header.css&lt;/code&gt;&lt;strong&gt; (komplett, korrigiert, final)&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;/* HEADER WRAPPER */&lt;br/&gt;.mmz-header {&lt;br/&gt;  width: 100%;&lt;br/&gt;  background: #fff;&lt;br/&gt;  font-family: system-ui, sans-serif;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* --------------------------------------------- */&lt;br/&gt;/* TOP BAR */&lt;br/&gt;/* --------------------------------------------- */&lt;br/&gt;&lt;br/&gt;.mmz-topbar {&lt;br/&gt;  padding: 6px 0;&lt;br/&gt;  border-bottom: none; /* WICHTIG: damit Switch und Navbar zusammenkleben */&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* SWITCH BOX (Suchender / Vermieter) */&lt;br/&gt;.mmz-switch {&lt;br/&gt;  display: flex;&lt;br/&gt;  border: 1px solid #dcdcdc;&lt;br/&gt;  border-radius: 6px;&lt;br/&gt;  overflow: hidden;&lt;br/&gt;  margin-right: 16px;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Einzelner Tab */&lt;br/&gt;.mmz-switch-item {&lt;br/&gt;  padding: 6px 14px;&lt;br/&gt;  font-size: 14px;&lt;br/&gt;  cursor: pointer;&lt;br/&gt;  background: #fff;&lt;br/&gt;  color: #333;&lt;br/&gt;  transition: 0.2s;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Aktiver Tab = GELB */&lt;br/&gt;.mmz-switch-item.active {&lt;br/&gt;  background: #ffd200; /* Original Gelb */&lt;br/&gt;  font-weight: 600;&lt;br/&gt;  color: #000;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Flagge */&lt;br/&gt;.flag-de {&lt;br/&gt;  width: 22px;&lt;br/&gt;  height: 16px;&lt;br/&gt;  background-image: url(&quot;/flag-de.png&quot;);&lt;br/&gt;  background-size: cover;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* --------------------------------------------- */&lt;br/&gt;/* NAVBAR */&lt;br/&gt;/* --------------------------------------------- */&lt;br/&gt;&lt;br/&gt;.mmz-navbar {&lt;br/&gt;  padding: 14px 0;&lt;br/&gt;  transition: background 0.2s;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Wenn &quot;Suchender&quot; aktiv */&lt;br/&gt;.mmz-navbar-customer {&lt;br/&gt;  background: #ffd200; /* GELB */&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Wenn &quot;Vermieter&quot; aktiv */&lt;br/&gt;.mmz-navbar-landlord {&lt;br/&gt;  background: #ffffff; /* WEISS */&lt;br/&gt;  border-bottom: 1px solid #e5e5e5;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* NAV ITEMS */&lt;br/&gt;.mmz-item {&lt;br/&gt;  font-size: 15px;&lt;br/&gt;  color: #333 !important;&lt;br/&gt;  padding: 6px 10px;&lt;br/&gt;  border-radius: 6px;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;.mmz-item:hover {&lt;br/&gt;  background: #f2f2f2;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* BURGER ICON */&lt;br/&gt;.mmz-burger {&lt;br/&gt;  cursor: pointer;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* --------------------------------------------- */&lt;br/&gt;/* MOBILE MENU */&lt;br/&gt;/* --------------------------------------------- */&lt;br/&gt;&lt;br/&gt;.mmz-mobile {&lt;br/&gt;  background: #fff;&lt;br/&gt;  border-top: 1px solid #e5e5e5;&lt;br/&gt;  padding: 20px 0;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔥 &lt;strong&gt;Was wurde verbessert?&lt;/strong&gt;&lt;/h1&gt;&lt;h3&gt;✔ 1. &lt;code&gt;activeTab&lt;/code&gt; färbt jetzt auch die Navbar&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Die Navbar bekommt automatisch:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;gelb&lt;/strong&gt;, wenn „Suchender“ aktiv ist&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;weiß&lt;/strong&gt;, wenn „Vermieter“ aktiv ist&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;h3&gt;✔ 2. Top‑Bar und Navbar „kleben“ jetzt optisch zusammen&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Kein grauer Balken mehr dazwischen.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;✔ 3. Switch‑Box und Navbar haben exakt dieselbe gelbe Farbe&lt;/h3&gt;&lt;p&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;p&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space: pre-wrap;&quot;&gt;Dadurch wirkt es wie ein durchgehender Block — wie beim Original.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="2060" width="950" x="-3820" y="2300" as="geometry" />
        </mxCell>
        <mxCell id="pQg1HVivcMeYRdmA5alk-11" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;ZJ5zaT2FAWKfrjvJHHfuf-author ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div id=&quot;ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — ich sehe &lt;strong&gt;sofort&lt;/strong&gt;, warum es bei dir nicht funktioniert:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 &lt;strong&gt;Der Fehler steckt in genau EINER Zeile.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Und zwar hier:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;className={&lt;br/&gt;    &quot;mmz-navbar&quot; +&lt;br/&gt;    (activeTab === &quot;suchender&quot; ? &quot;mmz-navbar-customer&quot; : &quot;mmz-navbar-landlord&quot;)&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ergibt am Ende so etwas wie:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&quot;mmz-navbarmmz-navbar-customer&quot;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ &lt;strong&gt;Es fehlt ein Leerzeichen!&lt;/strong&gt;  &lt;br/&gt;Dadurch wird die Klasse nicht erkannt → die Navbar wird &lt;strong&gt;nie gelb&lt;/strong&gt; → und sie grenzt sich nicht sauber an den Switch an.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;KORREKT&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;className={&lt;br/&gt;    &quot;mmz-navbar &quot; +&lt;br/&gt;    (activeTab === &quot;suchender&quot; ? &quot;mmz-navbar-customer&quot; : &quot;mmz-navbar-landlord&quot;)&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beachte das Leerzeichen nach &lt;code&gt;&quot;mmz-navbar &quot;&lt;/code&gt;.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔥 Zweiter Fehler: Du hast dich vertippt&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du hast:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;setMobilOpen(!mobileOpen)&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;aber dein State heißt:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;const [mobileOpen, setMobilOpen] = useState(false);&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ &lt;code&gt;setMobilOpen&lt;/code&gt; ist falsch geschrieben&lt;br/&gt;➡ Es muss &lt;code&gt;setMobileOpen&lt;/code&gt; heißen&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;KORREKT&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;const [mobileOpen, setMobileOpen] = useState(false);&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Und:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;onClick={() =&amp;gt; setMobileOpen(!mobileOpen)}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🟡 Dritter Fehler: Deine Navbar‑Klassen funktionieren nicht&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du hast in CSS:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;.mmz-navbar-customer { background: #ffd200; }&lt;br/&gt;.mmz-navbar-landlord { background: #fff; }&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Aber deine Klasse wird so erzeugt:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&quot;mmz-navbar mmz-navbar-customer&quot;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ Das ist korrekt — ABER nur, wenn das Leerzeichen drin ist.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;Hier ist der komplett korrigierte Navbar‑Block&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;Navbar &lt;br/&gt;    expand=&quot;lg&quot; &lt;br/&gt;    className={&lt;br/&gt;        &quot;mmz-navbar &quot; +&lt;br/&gt;        (activeTab === &quot;suchender&quot; ? &quot;mmz-navbar-customer&quot; : &quot;mmz-navbar-landlord&quot;)&lt;br/&gt;    }&lt;br/&gt;&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 Ergebnis nach diesen Fixes&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der gelbe Switch &lt;strong&gt;verschmilzt&lt;/strong&gt; optisch mit der gelben Navbar&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du „Vermieter“ klickst → Navbar wird weiß&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles sieht aus wie beim Original&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Keine weißen Links mehr auf gelbem Hintergrund&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Mobile Menü funktioniert wieder&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Wenn du willst, gebe ich dir jetzt die &lt;strong&gt;komplett korrigierte Header.jsx&lt;/strong&gt;, fertig zum Einfügen.&lt;/h1&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="1720" width="950" x="-3850" y="4460" as="geometry" />
        </mxCell>
        <mxCell id="pQg1HVivcMeYRdmA5alk-12" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;ZJ5zaT2FAWKfrjvJHHfuf-author ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div id=&quot;ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — jetzt bauen wir die &lt;strong&gt;Top‑Navigation „Suchender / Vermieter“ so nach&lt;/strong&gt;, dass:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;beide Tabs &lt;strong&gt;direkt nebeneinander&lt;/strong&gt; stehen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;sie &lt;strong&gt;einen gemeinsamen Rahmen&lt;/strong&gt; haben&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der aktive Tab &lt;strong&gt;gelb hinterlegt&lt;/strong&gt; ist&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der Rahmen &lt;strong&gt;durchgehend&lt;/strong&gt; ist (wie beim Original)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;React‑Bootstrap verwendet wird&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;der aktive Zustand per React‑State gesteuert wird&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Genau so funktioniert es auf mein‑monteurzimmer.de.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;React‑Bootstrap Version mit gemeinsamem Rahmen + gelbem aktiven Tab&lt;/strong&gt;&lt;/h1&gt;&lt;h2&gt;📁 &lt;code&gt;Header.jsx&lt;/code&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { useState } from &quot;react&quot;;&lt;br/&gt;import { Container } from &quot;react-bootstrap&quot;;&lt;br/&gt;import &quot;./header.css&quot;;&lt;br/&gt;&lt;br/&gt;export default function Header() {&lt;br/&gt;  const [activeTab, setActiveTab] = useState(&quot;suchender&quot;);&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;header className=&quot;mmz-header&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* TOP BAR */}&lt;br/&gt;      &amp;lt;div className=&quot;mmz-topbar&quot;&amp;gt;&lt;br/&gt;        &amp;lt;Container className=&quot;d-flex justify-content-end&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;          &amp;lt;div className=&quot;mmz-switch&quot;&amp;gt;&lt;br/&gt;            &amp;lt;span&lt;br/&gt;              className={&lt;br/&gt;                &quot;mmz-switch-item &quot; +&lt;br/&gt;                (activeTab === &quot;suchender&quot; ? &quot;active&quot; : &quot;&quot;)&lt;br/&gt;              }&lt;br/&gt;              onClick={() =&amp;gt; setActiveTab(&quot;suchender&quot;)}&lt;br/&gt;            &amp;gt;&lt;br/&gt;              Suchender&lt;br/&gt;            &amp;lt;/span&amp;gt;&lt;br/&gt;&lt;br/&gt;            &amp;lt;span&lt;br/&gt;              className={&lt;br/&gt;                &quot;mmz-switch-item &quot; +&lt;br/&gt;                (activeTab === &quot;vermieter&quot; ? &quot;active&quot; : &quot;&quot;)&lt;br/&gt;              }&lt;br/&gt;              onClick={() =&amp;gt; setActiveTab(&quot;vermieter&quot;)}&lt;br/&gt;            &amp;gt;&lt;br/&gt;              Vermieter&lt;br/&gt;            &amp;lt;/span&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;          &amp;lt;div className=&quot;mmz-flag flag-de&quot;&amp;gt;&amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;/Container&amp;gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* ... Rest vom Header */}&lt;br/&gt;    &amp;lt;/header&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎨 &lt;strong&gt;CSS für gemeinsamen Rahmen + gelben aktiven Tab&lt;/strong&gt;&lt;/h1&gt;&lt;h2&gt;📁 &lt;code&gt;header.css&lt;/code&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;/* Top Bar */&lt;br/&gt;.mmz-topbar {&lt;br/&gt;  background: #f7f7f7;&lt;br/&gt;  border-bottom: 1px solid #e5e5e5;&lt;br/&gt;  padding: 6px 0;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* SWITCH BOX (Suchender / Vermieter) */&lt;br/&gt;.mmz-switch {&lt;br/&gt;  display: flex;&lt;br/&gt;  border: 1px solid #dcdcdc;&lt;br/&gt;  border-radius: 6px;&lt;br/&gt;  overflow: hidden;&lt;br/&gt;  margin-right: 16px;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Einzelner Tab */&lt;br/&gt;.mmz-switch-item {&lt;br/&gt;  padding: 6px 14px;&lt;br/&gt;  font-size: 14px;&lt;br/&gt;  cursor: pointer;&lt;br/&gt;  background: #fff;&lt;br/&gt;  color: #333;&lt;br/&gt;  transition: 0.2s;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Aktiver Tab = GELB */&lt;br/&gt;.mmz-switch-item.active {&lt;br/&gt;  background: #ffd200; /* Original Gelb */&lt;br/&gt;  font-weight: 600;&lt;br/&gt;  color: #000;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Flagge */&lt;br/&gt;.flag-de {&lt;br/&gt;  width: 22px;&lt;br/&gt;  height: 16px;&lt;br/&gt;  background-image: url(&quot;/flag-de.png&quot;);&lt;br/&gt;  background-size: cover;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 Ergebnis&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du bekommst jetzt:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Einen gemeinsamen Rahmen&lt;/strong&gt; um beide Tabs&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Tabs direkt nebeneinander&lt;/strong&gt;, ohne Abstand&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Gelber aktiver Tab&lt;/strong&gt;, wie beim Original&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Rechtsbündige Ausrichtung&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;React‑State&lt;/strong&gt;, um den aktiven Tab zu steuern&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;React‑Bootstrap kompatibel&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;So sieht es dann aus:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;[ Suchender | Vermieter ]  🇩🇪&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn „Suchender“ aktiv ist:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;[ SUCHENDER | Vermieter ]  🇩🇪&lt;br/&gt;   gelb&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Willst du, dass wir jetzt:&lt;/h1&gt;&lt;h3&gt;🔹 Die Hauptnavigation darunter (Logo + Menü) exakt nachbauen?&lt;/h3&gt;&lt;h3&gt;🔹 Die Suchbox unter dem Header 1:1 nachbauen?&lt;/h3&gt;&lt;h3&gt;🔹 Mobile Version wie beim Original machen?&lt;/h3&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="2340" width="950" x="-2650" y="9934" as="geometry" />
        </mxCell>
        <mxCell id="pQg1HVivcMeYRdmA5alk-13" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;ZJ5zaT2FAWKfrjvJHHfuf-author ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div id=&quot;ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot;&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="4160" width="950" x="-8170" y="-90" as="geometry" />
        </mxCell>
        <mxCell id="pQg1HVivcMeYRdmA5alk-14" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;ZJ5zaT2FAWKfrjvJHHfuf-author ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div id=&quot;ZJ5zaT2FAWKfrjvJHHfuf-content-0&quot;&gt;&lt;div data-testid=&quot;backstage-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;pcpoYjVZDb9M675X5Pqs6-author pcpoYjVZDb9M675X5Pqs6-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div&gt;&lt;div id=&quot;pcpoYjVZDb9M675X5Pqs6-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — ich sehe &lt;strong&gt;sofort&lt;/strong&gt;, warum es bei dir nicht funktioniert:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 &lt;strong&gt;Der Fehler steckt in genau EINER Zeile.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Und zwar hier:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;className={&lt;br/&gt;    &quot;mmz-navbar&quot; +&lt;br/&gt;    (activeTab === &quot;suchender&quot; ? &quot;mmz-navbar-customer&quot; : &quot;mmz-navbar-landlord&quot;)&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ergibt am Ende so etwas wie:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&quot;mmz-navbarmmz-navbar-customer&quot;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ &lt;strong&gt;Es fehlt ein Leerzeichen!&lt;/strong&gt;  &lt;br/&gt;Dadurch wird die Klasse nicht erkannt → die Navbar wird &lt;strong&gt;nie gelb&lt;/strong&gt; → und sie grenzt sich nicht sauber an den Switch an.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;KORREKT&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;className={&lt;br/&gt;    &quot;mmz-navbar &quot; +&lt;br/&gt;    (activeTab === &quot;suchender&quot; ? &quot;mmz-navbar-customer&quot; : &quot;mmz-navbar-landlord&quot;)&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beachte das Leerzeichen nach &lt;code&gt;&quot;mmz-navbar &quot;&lt;/code&gt;.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔥 Zweiter Fehler: Du hast dich vertippt&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du hast:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;setMobilOpen(!mobileOpen)&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;aber dein State heißt:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;const [mobileOpen, setMobilOpen] = useState(false);&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ &lt;code&gt;setMobilOpen&lt;/code&gt; ist falsch geschrieben&lt;br/&gt;➡ Es muss &lt;code&gt;setMobileOpen&lt;/code&gt; heißen&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;KORREKT&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;const [mobileOpen, setMobileOpen] = useState(false);&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Und:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;onClick={() =&amp;gt; setMobileOpen(!mobileOpen)}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🟡 Dritter Fehler: Deine Navbar‑Klassen funktionieren nicht&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du hast in CSS:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;.mmz-navbar-customer { background: #ffd200; }&lt;br/&gt;.mmz-navbar-landlord { background: #fff; }&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Aber deine Klasse wird so erzeugt:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&quot;mmz-navbar mmz-navbar-customer&quot;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ Das ist korrekt — ABER nur, wenn das Leerzeichen drin ist.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;Hier ist der komplett korrigierte Navbar‑Block&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;Navbar &lt;br/&gt;    expand=&quot;lg&quot; &lt;br/&gt;    className={&lt;br/&gt;        &quot;mmz-navbar &quot; +&lt;br/&gt;        (activeTab === &quot;suchender&quot; ? &quot;mmz-navbar-customer&quot; : &quot;mmz-navbar-landlord&quot;)&lt;br/&gt;    }&lt;br/&gt;&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 Ergebnis nach diesen Fixes&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der gelbe Switch &lt;strong&gt;verschmilzt&lt;/strong&gt; optisch mit der gelben Navbar&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du „Vermieter“ klickst → Navbar wird weiß&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles sieht aus wie beim Original&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Keine weißen Links mehr auf gelbem Hintergrund&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Mobile Menü funktioniert wieder&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Wenn du willst, gebe ich dir jetzt die &lt;strong&gt;komplett korrigierte Header.jsx&lt;/strong&gt;, fertig zum Einfügen.&lt;/h1&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;min-h-[calc(100%-56px)] flex shrink-0 flex-col&quot; data-testid=&quot;highlighted-chats&quot;&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; id=&quot;RTFQUgS8iUmqzkimwF1RT-user-message&quot; aria-labelledby=&quot;RTFQUgS8iUmqzkimwF1RT-user-message&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div class=&quot;flex w-full flex-col gap-1&quot;&gt;&lt;div class=&quot;font-ligatures-none relative h-fit max-w-user-text-message whitespace-pre-wrap break-words px-4 py-2.5 squircle-16 bg-accent-250/60 dark:bg-accent-200 text-base self-end&quot; data-content=&quot;user-message&quot;&gt;Also das Problemm ist immer noch da. Knopf Suchende farblich gränzt nicht mit dem Navigationsleiste&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div data-tabster=&quot;{&amp;quot;groupper&amp;quot;:{&amp;quot;tabbability&amp;quot;:2},&amp;quot;focusable&amp;quot;:{}}&quot; data-content=&quot;ai-message&quot; data-testid=&quot;ai-message&quot; aria-labelledby=&quot;cmgnJvb7CSGngQwh8XWih-author cmgnJvb7CSGngQwh8XWih-content-0&quot; tabindex=&quot;0&quot; role=&quot;article&quot;&gt;&lt;div&gt;&lt;/div&gt;&lt;div class=&quot;space-y-3 mt-3&quot;&gt;&lt;div id=&quot;cmgnJvb7CSGngQwh8XWih-content-0&quot;&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — &lt;strong&gt;jetzt weiß ich ganz genau, warum dein gelber „Suchender“-Button NICHT bündig mit der gelben Navbar abschließt.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 &lt;strong&gt;Der Fehler liegt NICHT im State.&lt;/strong&gt;  &lt;br/&gt;👉 &lt;strong&gt;Der Fehler liegt NICHT im JSX.&lt;/strong&gt;  &lt;br/&gt;👉 &lt;strong&gt;Der Fehler liegt zu 100 % in deinem CSS — und zwar in der Reihenfolge und im Layout.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich zeige dir jetzt &lt;strong&gt;den exakten Grund&lt;/strong&gt; und gebe dir &lt;strong&gt;die funktionierende Lösung&lt;/strong&gt;, die sofort wirkt.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🚨 &lt;strong&gt;WARUM ES NICHT BÜNDIG IST&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der Switch sitzt in:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;.mmz-topbar&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Die Navbar sitzt darunter in:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;.mmz-navbar&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beide haben &lt;strong&gt;unterschiedliche Hintergründe&lt;/strong&gt;:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;Topbar:&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;.mmz-topbar {&lt;br/&gt;  background: #f7f7f7;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;h3&gt;Navbar (bei Suchender):&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;.mmz-navbar-customer {&lt;br/&gt;  background: #ffd200;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;➡ &lt;strong&gt;Das bedeutet:&lt;/strong&gt;  &lt;br/&gt;Der Switch ist GELB, aber der Bereich dahinter ist GRAU.&lt;br/&gt;Die Navbar ist GELB, aber der Bereich darüber ist GRAU.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Darum sieht es so aus:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;[ GELB ]   ← Switch&lt;br/&gt;------------&lt;br/&gt; GRAU      ← Topbar Hintergrund&lt;br/&gt;------------&lt;br/&gt; GELB      ← Navbar&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Natürlich „grenzt“ das nicht bündig.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;DIE LÖSUNG (funktioniert 100 %)&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wir müssen die &lt;strong&gt;Topbar-Hintergrundfarbe dynamisch&lt;/strong&gt; anpassen, genau wie die Navbar.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;FERTIGE, FUNKTIONIERENDE header.css&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bitte ersetze deine Topbar‑Sektion durch diese Version:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;/* Top Bar */&lt;br/&gt;.mmz-topbar {&lt;br/&gt;  padding: 6px 0;&lt;br/&gt;  border-bottom: none;&lt;br/&gt;  transition: background 0.2s;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Wenn Suchender aktiv → Topbar GELB */&lt;br/&gt;.mmz-topbar-customer {&lt;br/&gt;  background: #ffd200;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;/* Wenn Vermieter aktiv → Topbar WEISS */&lt;br/&gt;.mmz-topbar-landlord {&lt;br/&gt;  background: #ffffff;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Und die Navbar bleibt so:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;css&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;.mmz-navbar-customer {&lt;br/&gt;  background: #ffd200;&lt;br/&gt;}&lt;br/&gt;&lt;br/&gt;.mmz-navbar-landlord {&lt;br/&gt;  background: #ffffff;&lt;br/&gt;  border-bottom: 1px solid #e5e5e5;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;JETZT Header.jsx anpassen&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du musst der Topbar dieselbe Logik geben wie der Navbar:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;❌ Deine aktuelle Version:&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;div className=&quot;mmz-topbar&quot;&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;h3&gt;✔ KORREKT:&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;div&lt;br/&gt;  className={&lt;br/&gt;    &quot;mmz-topbar &quot; +&lt;br/&gt;    (activeTab === &quot;suchender&quot;&lt;br/&gt;      ? &quot;mmz-topbar-customer&quot;&lt;br/&gt;      : &quot;mmz-topbar-landlord&quot;)&lt;br/&gt;  }&lt;br/&gt;&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 &lt;strong&gt;ERGEBNIS&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Jetzt sieht es so aus:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;Wenn „Suchender“ aktiv:&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;[GELB] Switch&lt;br/&gt;[GELB] Topbar&lt;br/&gt;[GELB] Navbar&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;→ &lt;strong&gt;Alles bündig, keine Lücke, exakt wie beim Original&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;Wenn „Vermieter“ aktiv:&lt;/h3&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;[WEISS] Switch&lt;br/&gt;[WEISS] Topbar&lt;br/&gt;[WEISS] Navbar&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;→ &lt;strong&gt;Auch bündig, sauber, professionell&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Wenn du willst, kann ich dir jetzt auch:&lt;/h1&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;die &lt;strong&gt;exakte Original‑Hover‑Farbe&lt;/strong&gt; geben&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;die &lt;strong&gt;mobile Version&lt;/strong&gt; perfekt anpassen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;die &lt;strong&gt;Suchbox&lt;/strong&gt; unter dem Header 1:1 nachbauen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag einfach Bescheid.&lt;/span&gt;&lt;/p&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
