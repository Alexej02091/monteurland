        <mxCell id="Tj8YYApBm8QszppxP4FJ-3" parent="1" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;strokeWidth=8;width=140;height=30;" value="App.jsx" vertex="1">
