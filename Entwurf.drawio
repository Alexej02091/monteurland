        <mxCell id="LqXvwYY59BlQr5JXUkB3-120" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — du bekommst jetzt den &lt;strong&gt;kompletten, sauberen und funktionierenden Code für den gesamten &lt;/strong&gt;&lt;code&gt;vermieter/&lt;/code&gt;&lt;strong&gt;‑Bereich&lt;/strong&gt;:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ &lt;code&gt;Dashboard.jsx&lt;/code&gt;  &lt;br/&gt;✔ &lt;code&gt;InseratErstellen.jsx&lt;/code&gt;  &lt;br/&gt;✔ &lt;code&gt;InseratBearbeiten.jsx&lt;/code&gt;  &lt;br/&gt;✔ &lt;code&gt;Buchungen.jsx&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alle Dateien sind:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bootstrap‑ready&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;logisch aufgebaut&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;später leicht mit API‑Calls erweiterbar&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;kompatibel mit deinem Auth‑ und Routing‑System&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📁 &lt;strong&gt;1. &lt;/strong&gt;&lt;code&gt;Dashboard.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/pages/vermieter/Dashboard.jsx&lt;br/&gt;export default function Dashboard() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div&amp;gt;&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Vermieter Dashboard&amp;lt;/h1&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;div className=&quot;row g-3&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;col-md-4&quot;&amp;gt;&lt;br/&gt;          &amp;lt;div className=&quot;card p-3&quot;&amp;gt;&lt;br/&gt;            &amp;lt;h5&amp;gt;Inserate&amp;lt;/h5&amp;gt;&lt;br/&gt;            &amp;lt;p&amp;gt;Verwalte deine bestehenden Inserate.&amp;lt;/p&amp;gt;&lt;br/&gt;            &amp;lt;a href=&quot;/vermieter/inserat-erstellen&quot; className=&quot;btn btn-primary&quot;&amp;gt;&lt;br/&gt;              Neues Inserat erstellen&lt;br/&gt;            &amp;lt;/a&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;col-md-4&quot;&amp;gt;&lt;br/&gt;          &amp;lt;div className=&quot;card p-3&quot;&amp;gt;&lt;br/&gt;            &amp;lt;h5&amp;gt;Buchungen&amp;lt;/h5&amp;gt;&lt;br/&gt;            &amp;lt;p&amp;gt;Sieh dir aktuelle und vergangene Buchungen an.&amp;lt;/p&amp;gt;&lt;br/&gt;            &amp;lt;a href=&quot;/vermieter/buchungen&quot; className=&quot;btn btn-secondary&quot;&amp;gt;&lt;br/&gt;              Buchungen ansehen&lt;br/&gt;            &amp;lt;/a&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📁 &lt;strong&gt;2. &lt;/strong&gt;&lt;code&gt;InseratErstellen.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/pages/vermieter/InseratErstellen.jsx&lt;br/&gt;import { useState } from &quot;react&quot;;&lt;br/&gt;&lt;br/&gt;export default function InseratErstellen() {&lt;br/&gt;  const [title, setTitle] = useState(&quot;&quot;);&lt;br/&gt;  const [price, setPrice] = useState(&quot;&quot;);&lt;br/&gt;  const [description, setDescription] = useState(&quot;&quot;);&lt;br/&gt;&lt;br/&gt;  const handleSubmit = (e) =&amp;gt; {&lt;br/&gt;    e.preventDefault();&lt;br/&gt;&lt;br/&gt;    console.log(&quot;Neues Inserat:&quot;, {&lt;br/&gt;      title,&lt;br/&gt;      price,&lt;br/&gt;      description&lt;br/&gt;    });&lt;br/&gt;&lt;br/&gt;    alert(&quot;Inserat wurde erstellt (Demo)&quot;);&lt;br/&gt;  };&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;col-md-8 mx-auto&quot;&amp;gt;&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Neues Inserat erstellen&amp;lt;/h1&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;form onSubmit={handleSubmit}&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Titel&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;input&lt;br/&gt;            type=&quot;text&quot;&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            value={title}&lt;br/&gt;            onChange={(e) =&amp;gt; setTitle(e.target.value)}&lt;br/&gt;            placeholder=&quot;z.B. Moderne Wohnung im Zentrum&quot;&lt;br/&gt;          /&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Preis (€/Monat)&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;input&lt;br/&gt;            type=&quot;number&quot;&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            value={price}&lt;br/&gt;            onChange={(e) =&amp;gt; setPrice(e.target.value)}&lt;br/&gt;            placeholder=&quot;1200&quot;&lt;br/&gt;          /&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Beschreibung&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;textarea&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            rows=&quot;5&quot;&lt;br/&gt;            value={description}&lt;br/&gt;            onChange={(e) =&amp;gt; setDescription(e.target.value)}&lt;br/&gt;            placeholder=&quot;Beschreibe die Wohnung...&quot;&lt;br/&gt;          &amp;gt;&amp;lt;/textarea&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;button type=&quot;submit&quot; className=&quot;btn btn-success w-100&quot;&amp;gt;&lt;br/&gt;          Inserat erstellen&lt;br/&gt;        &amp;lt;/button&amp;gt;&lt;br/&gt;      &amp;lt;/form&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📁 &lt;strong&gt;3. &lt;/strong&gt;&lt;code&gt;InseratBearbeiten.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/pages/vermieter/InseratBearbeiten.jsx&lt;br/&gt;import { useParams } from &quot;react-router-dom&quot;;&lt;br/&gt;import { useState, useEffect } from &quot;react&quot;;&lt;br/&gt;&lt;br/&gt;export default function InseratBearbeiten() {&lt;br/&gt;  const { id } = useParams();&lt;br/&gt;&lt;br/&gt;  const [title, setTitle] = useState(&quot;&quot;);&lt;br/&gt;  const [price, setPrice] = useState(&quot;&quot;);&lt;br/&gt;  const [description, setDescription] = useState(&quot;&quot;);&lt;br/&gt;&lt;br/&gt;  useEffect(() =&amp;gt; {&lt;br/&gt;    // Fake-Daten (später API)&lt;br/&gt;    const fakeData = {&lt;br/&gt;      title: &quot;Beispiel-Inserat&quot;,&lt;br/&gt;      price: 1200,&lt;br/&gt;      description: &quot;Schöne Wohnung im Zentrum.&quot;&lt;br/&gt;    };&lt;br/&gt;&lt;br/&gt;    setTitle(fakeData.title);&lt;br/&gt;    setPrice(fakeData.price);&lt;br/&gt;    setDescription(fakeData.description);&lt;br/&gt;  }, [id]);&lt;br/&gt;&lt;br/&gt;  const handleSubmit = (e) =&amp;gt; {&lt;br/&gt;    e.preventDefault();&lt;br/&gt;&lt;br/&gt;    console.log(&quot;Bearbeitetes Inserat:&quot;, {&lt;br/&gt;      id,&lt;br/&gt;      title,&lt;br/&gt;      price,&lt;br/&gt;      description&lt;br/&gt;    });&lt;br/&gt;&lt;br/&gt;    alert(&quot;Inserat wurde gespeichert (Demo)&quot;);&lt;br/&gt;  };&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;col-md-8 mx-auto&quot;&amp;gt;&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Inserat bearbeiten&amp;lt;/h1&amp;gt;&lt;br/&gt;      &amp;lt;p className=&quot;text-muted&quot;&amp;gt;Inserat-ID: {id}&amp;lt;/p&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;form onSubmit={handleSubmit}&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Titel&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;input&lt;br/&gt;            type=&quot;text&quot;&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            value={title}&lt;br/&gt;            onChange={(e) =&amp;gt; setTitle(e.target.value)}&lt;br/&gt;          /&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Preis (€/Monat)&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;input&lt;br/&gt;            type=&quot;number&quot;&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            value={price}&lt;br/&gt;            onChange={(e) =&amp;gt; setPrice(e.target.value)}&lt;br/&gt;          /&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Beschreibung&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;textarea&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            rows=&quot;5&quot;&lt;br/&gt;            value={description}&lt;br/&gt;            onChange={(e) =&amp;gt; setDescription(e.target.value)}&lt;br/&gt;          &amp;gt;&amp;lt;/textarea&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;button type=&quot;submit&quot; className=&quot;btn btn-primary w-100&quot;&amp;gt;&lt;br/&gt;          Änderungen speichern&lt;br/&gt;        &amp;lt;/button&amp;gt;&lt;br/&gt;      &amp;lt;/form&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📁 &lt;strong&gt;4. &lt;/strong&gt;&lt;code&gt;Buchungen.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/pages/vermieter/Buchungen.jsx&lt;br/&gt;import { useEffect, useState } from &quot;react&quot;;&lt;br/&gt;&lt;br/&gt;export default function Buchungen() {&lt;br/&gt;  const [bookings, setBookings] = useState([]);&lt;br/&gt;&lt;br/&gt;  useEffect(() =&amp;gt; {&lt;br/&gt;    // Fake-Daten (später API)&lt;br/&gt;    const fakeBookings = [&lt;br/&gt;      {&lt;br/&gt;        id: 1,&lt;br/&gt;        mieter: &quot;Max Mustermann&quot;,&lt;br/&gt;        datum: &quot;2024-05-12&quot;,&lt;br/&gt;        status: &quot;Bestätigt&quot;&lt;br/&gt;      },&lt;br/&gt;      {&lt;br/&gt;        id: 2,&lt;br/&gt;        mieter: &quot;Anna Schmidt&quot;,&lt;br/&gt;        datum: &quot;2024-06-01&quot;,&lt;br/&gt;        status: &quot;Ausstehend&quot;&lt;br/&gt;      }&lt;br/&gt;    ];&lt;br/&gt;&lt;br/&gt;    setBookings(fakeBookings);&lt;br/&gt;  }, []);&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div&amp;gt;&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Buchungen&amp;lt;/h1&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;table className=&quot;table table-striped&quot;&amp;gt;&lt;br/&gt;        &amp;lt;thead&amp;gt;&lt;br/&gt;          &amp;lt;tr&amp;gt;&lt;br/&gt;            &amp;lt;th&amp;gt;ID&amp;lt;/th&amp;gt;&lt;br/&gt;            &amp;lt;th&amp;gt;Mieter&amp;lt;/th&amp;gt;&lt;br/&gt;            &amp;lt;th&amp;gt;Datum&amp;lt;/th&amp;gt;&lt;br/&gt;            &amp;lt;th&amp;gt;Status&amp;lt;/th&amp;gt;&lt;br/&gt;          &amp;lt;/tr&amp;gt;&lt;br/&gt;        &amp;lt;/thead&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;tbody&amp;gt;&lt;br/&gt;          {bookings.map((b) =&amp;gt; (&lt;br/&gt;            &amp;lt;tr key={b.id}&amp;gt;&lt;br/&gt;              &amp;lt;td&amp;gt;{b.id}&amp;lt;/td&amp;gt;&lt;br/&gt;              &amp;lt;td&amp;gt;{b.mieter}&amp;lt;/td&amp;gt;&lt;br/&gt;              &amp;lt;td&amp;gt;{b.datum}&amp;lt;/td&amp;gt;&lt;br/&gt;              &amp;lt;td&amp;gt;{b.status}&amp;lt;/td&amp;gt;&lt;br/&gt;            &amp;lt;/tr&amp;gt;&lt;br/&gt;          ))}&lt;br/&gt;        &amp;lt;/tbody&amp;gt;&lt;br/&gt;      &amp;lt;/table&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 &lt;strong&gt;Der komplette Vermieter‑Bereich ist jetzt fertig!&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du hast jetzt:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ Dashboard&lt;br/&gt;✔ Inserat erstellen&lt;br/&gt;✔ Inserat bearbeiten&lt;br/&gt;✔ Buchungen&lt;br/&gt;✔ Alles sauber strukturiert&lt;br/&gt;✔ Sofort einsatzbereit&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Was möchtest du als Nächstes?&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Hier sind sinnvolle nächste Schritte:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;gesuchter‑Bereich komplett bauen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;admin‑Bereich komplett bauen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;API‑Service erstellen (echte Daten statt Fake)&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Bild‑Upload für Inserate&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Formular‑Validierung&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Design verbessern&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, womit wir weitermachen.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="4490" width="740" x="-7300" y="-14960" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-121" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — ich gebe dir jetzt den &lt;strong&gt;kompletten, fertigen und sauberen Code für den gesamten &lt;/strong&gt;&lt;code&gt;gesuchter/&lt;/code&gt;&lt;strong&gt;‑Bereich&lt;/strong&gt;, genauso wie wir es für &lt;em&gt;vermieter&lt;/em&gt; und &lt;em&gt;admin&lt;/em&gt; gemacht haben.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der &lt;strong&gt;gesuchter‑Bereich&lt;/strong&gt; besteht aus:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ &lt;code&gt;GesuchterDashboard.jsx&lt;/code&gt;  &lt;br/&gt;✔ &lt;code&gt;GesuchterProfil.jsx&lt;/code&gt;  &lt;br/&gt;✔ &lt;code&gt;Favoriten.jsx&lt;/code&gt;  &lt;br/&gt;✔ &lt;code&gt;Anfragen.jsx&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alle Dateien enthalten:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;default exports&lt;/strong&gt; (damit dein Router keine Fehler wirft)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Bootstrap‑Layout&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Fake‑Daten&lt;/strong&gt;, die später durch API‑Calls ersetzt werden können&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;saubere Struktur&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📁 &lt;strong&gt;1. &lt;/strong&gt;&lt;code&gt;GesuchterDashboard.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/pages/gesuchter/GesuchterDashboard.jsx&lt;br/&gt;&lt;br/&gt;export default function GesuchterDashboard() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div&amp;gt;&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Gesuchter Dashboard&amp;lt;/h1&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;div className=&quot;row g-3&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;col-md-4&quot;&amp;gt;&lt;br/&gt;          &amp;lt;div className=&quot;card p-3&quot;&amp;gt;&lt;br/&gt;            &amp;lt;h5&amp;gt;Profil&amp;lt;/h5&amp;gt;&lt;br/&gt;            &amp;lt;p&amp;gt;Bearbeite deine persönlichen Daten.&amp;lt;/p&amp;gt;&lt;br/&gt;            &amp;lt;a href=&quot;/gesuchter/profile&quot; className=&quot;btn btn-primary&quot;&amp;gt;&lt;br/&gt;              Profil öffnen&lt;br/&gt;            &amp;lt;/a&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;col-md-4&quot;&amp;gt;&lt;br/&gt;          &amp;lt;div className=&quot;card p-3&quot;&amp;gt;&lt;br/&gt;            &amp;lt;h5&amp;gt;Favoriten&amp;lt;/h5&amp;gt;&lt;br/&gt;            &amp;lt;p&amp;gt;Deine gespeicherten Inserate.&amp;lt;/p&amp;gt;&lt;br/&gt;            &amp;lt;a href=&quot;/gesuchter/favoriten&quot; className=&quot;btn btn-secondary&quot;&amp;gt;&lt;br/&gt;              Favoriten ansehen&lt;br/&gt;            &amp;lt;/a&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;col-md-4&quot;&amp;gt;&lt;br/&gt;          &amp;lt;div className=&quot;card p-3&quot;&amp;gt;&lt;br/&gt;            &amp;lt;h5&amp;gt;Anfragen&amp;lt;/h5&amp;gt;&lt;br/&gt;            &amp;lt;p&amp;gt;Verwalte deine gesendeten Anfragen.&amp;lt;/p&amp;gt;&lt;br/&gt;            &amp;lt;a href=&quot;/gesuchter/anfragen&quot; className=&quot;btn btn-dark&quot;&amp;gt;&lt;br/&gt;              Anfragen öffnen&lt;br/&gt;            &amp;lt;/a&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📁 &lt;strong&gt;2. &lt;/strong&gt;&lt;code&gt;GesuchterProfil.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/pages/gesuchter/GesuchterProfil.jsx&lt;br/&gt;&lt;br/&gt;import { useState } from &quot;react&quot;;&lt;br/&gt;&lt;br/&gt;export default function GesuchterProfil() {&lt;br/&gt;  const [name, setName] = useState(&quot;Max Mustermann&quot;);&lt;br/&gt;  const [email, setEmail] = useState(&quot;max@test.de&quot;);&lt;br/&gt;  const [bio, setBio] = useState(&quot;Ich suche eine Wohnung in Hamburg.&quot;);&lt;br/&gt;&lt;br/&gt;  const handleSave = () =&amp;gt; {&lt;br/&gt;    alert(&quot;Profil gespeichert (Demo)&quot;);&lt;br/&gt;  };&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;col-md-8 mx-auto&quot;&amp;gt;&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Mein Profil&amp;lt;/h1&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;div className=&quot;card p-4&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Name&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;input&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            value={name}&lt;br/&gt;            onChange={(e) =&amp;gt; setName(e.target.value)}&lt;br/&gt;          /&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;E-Mail&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;input&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            value={email}&lt;br/&gt;            onChange={(e) =&amp;gt; setEmail(e.target.value)}&lt;br/&gt;          /&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br/&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Über mich&amp;lt;/label&amp;gt;&lt;br/&gt;          &amp;lt;textarea&lt;br/&gt;            className=&quot;form-control&quot;&lt;br/&gt;            rows=&quot;4&quot;&lt;br/&gt;            value={bio}&lt;br/&gt;            onChange={(e) =&amp;gt; setBio(e.target.value)}&lt;br/&gt;          &amp;gt;&amp;lt;/textarea&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;button className=&quot;btn btn-primary w-100&quot; onClick={handleSave}&amp;gt;&lt;br/&gt;          Speichern&lt;br/&gt;        &amp;lt;/button&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📁 &lt;strong&gt;3. &lt;/strong&gt;&lt;code&gt;Favoriten.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/pages/gesuchter/Favoriten.jsx&lt;br/&gt;&lt;br/&gt;import { useEffect, useState } from &quot;react&quot;;&lt;br/&gt;&lt;br/&gt;export default function Favoriten() {&lt;br/&gt;  const [favorites, setFavorites] = useState([]);&lt;br/&gt;&lt;br/&gt;  useEffect(() =&amp;gt; {&lt;br/&gt;    // Fake-Daten (später API)&lt;br/&gt;    const fakeFavorites = [&lt;br/&gt;      { id: 1, title: &quot;Moderne Wohnung in Hamburg&quot;, price: 1200 },&lt;br/&gt;      { id: 2, title: &quot;Gemütliches Apartment&quot;, price: 950 }&lt;br/&gt;    ];&lt;br/&gt;&lt;br/&gt;    setFavorites(fakeFavorites);&lt;br/&gt;  }, []);&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div&amp;gt;&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Meine Favoriten&amp;lt;/h1&amp;gt;&lt;br/&gt;&lt;br/&gt;      {favorites.length === 0 &amp;amp;&amp;amp; &amp;lt;p&amp;gt;Keine Favoriten gespeichert.&amp;lt;/p&amp;gt;}&lt;br/&gt;&lt;br/&gt;      &amp;lt;div className=&quot;row g-3&quot;&amp;gt;&lt;br/&gt;        {favorites.map((fav) =&amp;gt; (&lt;br/&gt;          &amp;lt;div key={fav.id} className=&quot;col-md-4&quot;&amp;gt;&lt;br/&gt;            &amp;lt;div className=&quot;card p-3&quot;&amp;gt;&lt;br/&gt;              &amp;lt;h5&amp;gt;{fav.title}&amp;lt;/h5&amp;gt;&lt;br/&gt;              &amp;lt;p&amp;gt;{fav.price} € / Monat&amp;lt;/p&amp;gt;&lt;br/&gt;              &amp;lt;a href={`/inserat/${fav.id}`} className=&quot;btn btn-outline-primary&quot;&amp;gt;&lt;br/&gt;                Anzeigen&lt;br/&gt;              &amp;lt;/a&amp;gt;&lt;br/&gt;            &amp;lt;/div&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        ))}&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;📁 &lt;strong&gt;4. &lt;/strong&gt;&lt;code&gt;Anfragen.jsx&lt;/code&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/pages/gesuchter/Anfragen.jsx&lt;br/&gt;&lt;br/&gt;import { useEffect, useState } from &quot;react&quot;;&lt;br/&gt;&lt;br/&gt;export default function Anfragen() {&lt;br/&gt;  const [requests, setRequests] = useState([]);&lt;br/&gt;&lt;br/&gt;  useEffect(() =&amp;gt; {&lt;br/&gt;    // Fake-Daten (später API)&lt;br/&gt;    const fakeRequests = [&lt;br/&gt;      {&lt;br/&gt;        id: 1,&lt;br/&gt;        inserat: &quot;Moderne Wohnung in Hamburg&quot;,&lt;br/&gt;        status: &quot;Ausstehend&quot;,&lt;br/&gt;        date: &quot;2024-05-10&quot;&lt;br/&gt;      },&lt;br/&gt;      {&lt;br/&gt;        id: 2,&lt;br/&gt;        inserat: &quot;Gemütliches Apartment&quot;,&lt;br/&gt;        status: &quot;Bestätigt&quot;,&lt;br/&gt;        date: &quot;2024-04-28&quot;&lt;br/&gt;      }&lt;br/&gt;    ];&lt;br/&gt;&lt;br/&gt;    setRequests(fakeRequests);&lt;br/&gt;  }, []);&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div&amp;gt;&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Meine Anfragen&amp;lt;/h1&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;table className=&quot;table table-striped&quot;&amp;gt;&lt;br/&gt;        &amp;lt;thead&amp;gt;&lt;br/&gt;          &amp;lt;tr&amp;gt;&lt;br/&gt;            &amp;lt;th&amp;gt;ID&amp;lt;/th&amp;gt;&lt;br/&gt;            &amp;lt;th&amp;gt;Inserat&amp;lt;/th&amp;gt;&lt;br/&gt;            &amp;lt;th&amp;gt;Status&amp;lt;/th&amp;gt;&lt;br/&gt;            &amp;lt;th&amp;gt;Datum&amp;lt;/th&amp;gt;&lt;br/&gt;          &amp;lt;/tr&amp;gt;&lt;br/&gt;        &amp;lt;/thead&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;tbody&amp;gt;&lt;br/&gt;          {requests.map((req) =&amp;gt; (&lt;br/&gt;            &amp;lt;tr key={req.id}&amp;gt;&lt;br/&gt;              &amp;lt;td&amp;gt;{req.id}&amp;lt;/td&amp;gt;&lt;br/&gt;              &amp;lt;td&amp;gt;{req.inserat}&amp;lt;/td&amp;gt;&lt;br/&gt;              &amp;lt;td&amp;gt;{req.status}&amp;lt;/td&amp;gt;&lt;br/&gt;              &amp;lt;td&amp;gt;{req.date}&amp;lt;/td&amp;gt;&lt;br/&gt;            &amp;lt;/tr&amp;gt;&lt;br/&gt;          ))}&lt;br/&gt;        &amp;lt;/tbody&amp;gt;&lt;br/&gt;      &amp;lt;/table&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 &lt;strong&gt;Der komplette gesuchter‑Bereich ist jetzt fertig!&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Du hast jetzt:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ Dashboard&lt;br/&gt;✔ Profil&lt;br/&gt;✔ Favoriten&lt;br/&gt;✔ Anfragen&lt;br/&gt;✔ Alles mit &lt;code&gt;export default&lt;/code&gt;  &lt;br/&gt;✔ Bootstrap‑ready&lt;br/&gt;✔ Sofort einsatzbereit&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Was möchtest du als Nächstes?&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Hier sind sinnvolle nächste Schritte:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Routing für gesuchter prüfen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Header dynamisch mit AuthContext verbinden&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;API‑Service bauen (echte Daten statt Fake)&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Inserat‑Detailseite erstellen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Suchfunktion implementieren&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, womit wir weitermachen.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="3890" width="680" x="-7250" y="-10360" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-122" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der Fehler ist &lt;strong&gt;glasklar&lt;/strong&gt;:&lt;/span&gt;&lt;/p&gt;&lt;blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;In deiner &lt;/strong&gt;&lt;code&gt;App.jsx&lt;/code&gt;&lt;strong&gt; verwendest du &lt;/strong&gt;&lt;code&gt;&amp;lt;AuthProvider&amp;gt;&lt;/code&gt;&lt;strong&gt; – aber du hast ihn nicht importiert.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das ist der einzige Grund für:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;AuthProvider is not defined&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;So muss deine &lt;/strong&gt;&lt;code&gt;App.jsx&lt;/code&gt;&lt;strong&gt; aussehen&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bitte ersetze deine Datei durch diese Version:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/App.jsx&lt;br/&gt;import MainLayout from &quot;./layouts/MainLayout&quot;;&lt;br/&gt;import AppRouter from &quot;./router/AppRouter&quot;;&lt;br/&gt;&lt;br/&gt;// ❗ WICHTIG: AuthProvider importieren&lt;br/&gt;import AuthProvider from &quot;./context/AuthContext&quot;;&lt;br/&gt;&lt;br/&gt;export default function App() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;AuthProvider&amp;gt;&lt;br/&gt;      &amp;lt;MainLayout&amp;gt;&lt;br/&gt;        &amp;lt;AppRouter /&amp;gt;&lt;br/&gt;      &amp;lt;/MainLayout&amp;gt;&lt;br/&gt;    &amp;lt;/AuthProvider&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧠 &lt;strong&gt;Warum passiert der Fehler?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du &lt;code&gt;&amp;lt;AuthProvider&amp;gt;&lt;/code&gt; benutzt, aber &lt;strong&gt;vergisst ihn zu importieren&lt;/strong&gt;, denkt React:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;„Was ist AuthProvider?“&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;„Ich kenne diese Variable nicht.“&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;→ &lt;strong&gt;ReferenceError&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔍 &lt;strong&gt;Bitte prüfe auch, ob der Pfad stimmt&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Deine Datei muss hier liegen:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;src/context/AuthContext.jsx&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Und sie muss &lt;strong&gt;default export&lt;/strong&gt; haben:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;export default function AuthProvider({ children }) {&lt;br/&gt;  ...&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du stattdessen hast:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;export function AuthProvider() { ... }&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;→ dann funktioniert der default‑Import nicht.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;Checkliste – alles muss so sein&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div tabindex=&quot;0&quot; role=&quot;group&quot; aria-label=&quot;Scrollbare Tabelle&quot;&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Datei&lt;/th&gt;&lt;th&gt;Muss enthalten&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;code&gt;src/context/AuthContext.jsx&lt;/code&gt;&lt;/td&gt;&lt;td&gt;&lt;code&gt;export default AuthProvider&lt;/code&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;code&gt;src/App.jsx&lt;/code&gt;&lt;/td&gt;&lt;td&gt;&lt;code&gt;import AuthProvider from &quot;./context/AuthContext&quot;&lt;/code&gt;&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;code&gt;main.jsx&lt;/code&gt;&lt;/td&gt;&lt;td&gt;rendert &lt;code&gt;&lt;/code&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;button aria-label=&quot;Tabelle kopieren&quot; type=&quot;button&quot; data-testid=&quot;copy-table-button&quot; data-spatial-navigation-autofocus=&quot;false&quot; data-tooltip-state=&quot;closed&quot;&gt;&lt;svg viewBox=&quot;0 0 20 20&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8 2C6.89543 2 6 2.89543 6 4V14C6 15.1046 6.89543 16 8 16H14C15.1046 16 16 15.1046 16 14V4C16 2.89543 15.1046 2 14 2H8ZM7 4C7 3.44772 7.44772 3 8 3H14C14.5523 3 15 3.44772 15 4V14C15 14.5523 14.5523 15 14 15H8C7.44772 15 7 14.5523 7 14V4ZM4 6.00001C4 5.25973 4.4022 4.61339 5 4.26758V14.5C5 15.8807 6.11929 17 7.5 17H13.7324C13.3866 17.5978 12.7403 18 12 18H7.5C5.567 18 4 16.433 4 14.5V6.00001Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;button aria-label=&quot;Tabelle herunterladen&quot; type=&quot;button&quot; data-testid=&quot;download-table-button&quot; data-spatial-navigation-autofocus=&quot;false&quot; data-tooltip-state=&quot;closed&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M18.2498 20.5009C18.664 20.5008 19 20.8365 19 21.2507C19 21.6649 18.6644 22.0008 18.2502 22.0009L5.25022 22.0047C4.836 22.0048 4.5 21.6691 4.5 21.2549C4.5 20.8407 4.83557 20.5048 5.24978 20.5047L18.2498 20.5009ZM11.6482 2.01271L11.75 2.00586C12.1297 2.00586 12.4435 2.28801 12.4932 2.65409L12.5 2.75586L12.499 16.4409L16.2208 12.7205C16.4871 12.4543 16.9038 12.4301 17.1974 12.648L17.2815 12.7206C17.5477 12.9869 17.5719 13.4036 17.354 13.6972L17.2814 13.7813L12.2837 18.7779C12.0176 19.044 11.6012 19.0683 11.3076 18.8507L11.2235 18.7782L6.22003 13.7816C5.92694 13.4889 5.92661 13.014 6.21931 12.7209C6.48539 12.4545 6.90204 12.43 7.1958 12.6477L7.27997 12.7202L10.999 16.4339L11 2.75586C11 2.37616 11.2822 2.06237 11.6482 2.01271L11.75 2.00586L11.6482 2.01271Z&quot; fill=&quot;currentColor&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;Wenn du willst, kann ich jetzt:&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 deinen kompletten AuthContext prüfen&lt;br/&gt;👉 deine gesamte App-Struktur validieren&lt;br/&gt;👉 dir eine funktionierende Komplettversion von &lt;code&gt;App.jsx&lt;/code&gt;, &lt;code&gt;main.jsx&lt;/code&gt;, &lt;code&gt;AuthContext.jsx&lt;/code&gt; geben&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag einfach Bescheid, wie wir weitermachen.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="1340" width="660" x="-6450" y="-14960" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-104" parent="1" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=275;height=40;" value="ProtectedRoute.jsx" vertex="1">
          <mxGeometry height="3700" width="4210" x="690" y="1370" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-105" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;&lt;div&gt;// src/router/ProtectedRoute.jsx&lt;/div&gt;&lt;div&gt;import { Navigate } from &quot;react-router-dom&quot;;&lt;/div&gt;&lt;div&gt;import { useAuth } from &quot;../hooks/useAuth&quot;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;export default function ProtectedRoute({ children, role }) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; const { user, role: userRole } = useAuth();&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; // 1. Nicht eingeloggt → Login&lt;/div&gt;&lt;div&gt;&amp;nbsp; if (!user) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; return &amp;lt;Navigate to=&quot;/login&quot; replace /&amp;gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; // 2. Rollenprüfung&lt;/div&gt;&lt;div&gt;&amp;nbsp; if (role) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; // Wenn mehrere Rollen erlaubt sind&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; if (Array.isArray(role)) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; if (!role.includes(userRole)) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return &amp;lt;Navigate to=&quot;/unauthorized&quot; replace /&amp;gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&amp;nbsp;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; // Wenn nur eine Rolle erlaubt ist&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; else {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; if (userRole !== role) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; return &amp;lt;Navigate to=&quot;/unauthorized&quot; replace /&amp;gt;;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; }&lt;/div&gt;&lt;div&gt;&amp;nbsp; }&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; // 3. Zugriff erlaubt&lt;/div&gt;&lt;div&gt;&amp;nbsp; return children;&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="483.99999999999994" width="350" x="716" y="1434.9986956521739" as="geometry" />
        </mxCell>
