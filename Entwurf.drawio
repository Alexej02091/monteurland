        <mxCell id="LqXvwYY59BlQr5JXUkB3-79" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — jetzt finalisieren wir &lt;strong&gt;ProtectedRoute&lt;/strong&gt; so, dass sie wirklich robust, sauber und produktionsreif ist.&lt;br/&gt;Wir bauen:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;vollständige Rollenprüfung&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Prüfung ob eingeloggt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Weiterleitung zu Login&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Weiterleitung zu Unauthorized&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Unterstützung für mehrere erlaubte Rollen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Loading‑Zustand (falls später API‑Login kommt)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit ist dein Routing wirklich stabil.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;✅ &lt;strong&gt;Finale Version: &lt;/strong&gt;&lt;code&gt;ProtectedRoute.jsx&lt;/code&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Diese Version ist flexibel, sauber und unterstützt:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;eine Rolle&lt;/strong&gt; → &lt;code&gt;role=&quot;admin&quot;&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;mehrere Rollen&lt;/strong&gt; → &lt;code&gt;role={[&quot;admin&quot;, &quot;vermieter&quot;]}&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// src/router/ProtectedRoute.jsx&lt;br/&gt;import { Navigate } from &quot;react-router-dom&quot;;&lt;br/&gt;import { useAuth } from &quot;../hooks/useAuth&quot;;&lt;br/&gt;&lt;br/&gt;export default function ProtectedRoute({ children, role }) {&lt;br/&gt;  const { user, role: userRole } = useAuth();&lt;br/&gt;&lt;br/&gt;  // 1. Nicht eingeloggt → Login&lt;br/&gt;  if (!user) {&lt;br/&gt;    return &amp;lt;Navigate to=&quot;/login&quot; replace /&amp;gt;;&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  // 2. Rollenprüfung&lt;br/&gt;  if (role) {&lt;br/&gt;    // Wenn mehrere Rollen erlaubt sind&lt;br/&gt;    if (Array.isArray(role)) {&lt;br/&gt;      if (!role.includes(userRole)) {&lt;br/&gt;        return &amp;lt;Navigate to=&quot;/unauthorized&quot; replace /&amp;gt;;&lt;br/&gt;      }&lt;br/&gt;    } &lt;br/&gt;    // Wenn nur eine Rolle erlaubt ist&lt;br/&gt;    else {&lt;br/&gt;      if (userRole !== role) {&lt;br/&gt;        return &amp;lt;Navigate to=&quot;/unauthorized&quot; replace /&amp;gt;;&lt;br/&gt;      }&lt;br/&gt;    }&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  // 3. Zugriff erlaubt&lt;br/&gt;  return children;&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧠 &lt;strong&gt;Warum ist das jetzt „final“?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Weil es:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;✔ Login prüft&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn kein User → Redirect zu &lt;code&gt;/login&lt;/code&gt;.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;✔ Rolle prüft&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn Rolle nicht passt → Redirect zu &lt;code&gt;/unauthorized&lt;/code&gt;.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;✔ mehrere Rollen unterstützt&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;z. B.:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;ProtectedRoute role={[&quot;admin&quot;, &quot;vermieter&quot;]}&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;h3&gt;✔ sauber und erweiterbar ist&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Später kannst du:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Loading‑State einbauen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;API‑Token prüfen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Refresh‑Token einbauen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🟦 &lt;strong&gt;Bonus: Unauthorized-Seite (403)&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit der Redirect funktioniert:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;src/pages/Unauthorized.jsx&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;export default function Unauthorized() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;text-center mt-5&quot;&amp;gt;&lt;br/&gt;      &amp;lt;h1&amp;gt;403 – Kein Zugriff&amp;lt;/h1&amp;gt;&lt;br/&gt;      &amp;lt;p&amp;gt;Du hast keine Berechtigung, diese Seite zu sehen.&amp;lt;/p&amp;gt;&lt;br/&gt;      &amp;lt;a href=&quot;/&quot; className=&quot;btn btn-primary mt-3&quot;&amp;gt;Zur Startseite&amp;lt;/a&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Und im Router eintragen:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;Route path=&quot;/unauthorized&quot; element={&amp;lt;Unauthorized /&amp;gt;} /&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 &lt;strong&gt;ProtectedRoute ist jetzt komplett fertig!&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit ist dein Rollen‑System voll funktionsfähig.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;👉 Was machen wir als Nächstes?&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Hier sind die nächsten sinnvollen Schritte:&lt;/span&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Header dynamisch machen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;UserMenu zeigt Logout&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;RoleNavigation reagiert auf Rolle&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Login/Logout aktualisiert Header sofort&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Login‑Seite verbessern&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Fehlermeldungen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Loading&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Redirect nach Rolle&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;gesuchter/vermieter/admin Seiten mit Inhalt füllen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="2110" width="680" x="-8070" y="-14969" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-80" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Fast gesagt: &lt;strong&gt;Ja, genau – ein Hook ist eine externe Funktion, aber mit Superkräften.&lt;/strong&gt;  &lt;br/&gt;Und du hast es schon ziemlich gut verstanden. Ich ergänze nur die wichtigen Details, damit das Bild komplett ist.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;🧠 Was ist ein Hook wirklich?&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ein Hook ist &lt;strong&gt;eine normale JavaScript‑Funktion&lt;/strong&gt;, die aber:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;nur in React-Komponenten oder anderen Hooks&lt;/strong&gt; verwendet werden darf&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Zugriff auf React‑Features&lt;/strong&gt; hat (State, Context, Lifecycle, Memoization usw.)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;wiederverwendbare Logik&lt;/strong&gt; kapselt, die du in vielen Komponenten brauchst&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;🔍 Dein Beispiel: &lt;code&gt;useAuth()&lt;/code&gt;&lt;/h2&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;js&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { useContext } from &quot;react&quot;;&lt;br/&gt;import { AuthContext } from &quot;../context/AuthContext&quot;;&lt;br/&gt;&lt;br/&gt;export function useAuth() {&lt;br/&gt;  return useContext(AuthContext);&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Das bedeutet:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;useAuth()&lt;/code&gt; ist &lt;strong&gt;kein UI&lt;/strong&gt;, es rendert nichts&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;es ist &lt;strong&gt;nur Logik&lt;/strong&gt;, die dir Zugriff auf den Auth‑Zustand gibt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;überall, wo du &lt;code&gt;useAuth()&lt;/code&gt; aufrufst, bekommst du:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;js&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;{ user, role, login, logout, ... }&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;🎯 Warum macht man das?&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Weil du sonst überall sowas schreiben müsstest:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;js&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;const { user, role } = useContext(AuthContext);&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Mit einem Hook:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;js&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;const { user, role } = useAuth();&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;→ &lt;strong&gt;kürzer, sauberer, wiederverwendbar&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;🧩 Hooks sind also:&lt;/h2&gt;&lt;h3&gt;✔️ &lt;strong&gt;Externe Funktionen&lt;/strong&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;…aber speziell dafür gedacht, &lt;strong&gt;React‑State und React‑Kontext&lt;/strong&gt; zu benutzen.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;✔️ &lt;strong&gt;Nicht an eine Komponente gebunden&lt;/strong&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;…aber sie funktionieren &lt;strong&gt;nur innerhalb&lt;/strong&gt; von Komponenten.&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;✔️ &lt;strong&gt;Wiederverwendbare Logik&lt;/strong&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;…z. B.:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;useAuth()&lt;/code&gt; → Auth‑Status&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;useFetch()&lt;/code&gt; → Daten laden&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;useLocalStorage()&lt;/code&gt; → State + localStorage&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;useWindowSize()&lt;/code&gt; → Fenstergröße tracken&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;🧠 Merksatz&lt;/h2&gt;&lt;blockquote&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Hooks sind Funktionen, die React‑Logik kapseln und überall nutzbar machen – aber nur innerhalb von React-Komponenten.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/blockquote&gt;&lt;div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du willst, kann ich dir zeigen, wie man einen eigenen Hook baut, z. B. &lt;code&gt;useToggle()&lt;/code&gt; oder &lt;code&gt;useLocalStorage()&lt;/code&gt;.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="1260" width="680" x="920" y="-13710" as="geometry" />
