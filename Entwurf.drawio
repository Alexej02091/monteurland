          <mxGeometry height="2930" width="4280" x="7210" y="-3160" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-100" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="920" width="840" x="7230" y="-3110" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-95" parent="LqXvwYY59BlQr5JXUkB3-100" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=100;height=30;" value="useAuth.js" vertex="1">
          <mxGeometry height="920" width="840" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-96" parent="LqXvwYY59BlQr5JXUkB3-100" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;import { useContext } from &quot;react&quot;;&lt;/div&gt;&lt;div&gt;import { AuthContext } from &quot;../context/AuthContext&quot;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;export function useAuth() {&lt;/div&gt;&lt;div&gt;&amp;nbsp; return useContext(AuthContext);&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="350" x="10" y="40" as="geometry" />
        </mxCell>
