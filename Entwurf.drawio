        <mxCell id="LqXvwYY59BlQr5JXUkB3-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;// src/layouts/MainLayout.jsx&lt;/div&gt;&lt;div&gt;import { useAuth } from &quot;../hooks/useAuth&quot;;&lt;/div&gt;&lt;div&gt;import Header from &quot;../components/header/Header&quot;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;export default function MainLayout({ children }) {&lt;/div&gt;&lt;div&gt;&amp;nbsp; const { user, role } = useAuth(); // z.B. role = &quot;guest&quot; | &quot;gesuchter&quot; | &quot;vermieter&quot; | &quot;admin&quot;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; return (&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;lt;div className=&quot;app-container&quot;&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;lt;Header role={role} user={user} /&amp;gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;lt;main className=&quot;content&quot;&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; {children}&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;lt;/main&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;lt;/div&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; );&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="260" width="510" x="-413" y="-2270" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-4" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;div&gt;&lt;div&gt;import MainLayout from &quot;./layouts/MainLayout&quot;;&lt;/div&gt;&lt;div&gt;import AppRouter from &quot;./router/AppRouter&quot;;&lt;/div&gt;&lt;div&gt;import AuthProvider from &quot;./context/AuthContext&quot;;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;export default function App() {&lt;/div&gt;&lt;div&gt;&amp;nbsp; return (&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;lt;AuthProvider&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;lt;MainLayout&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;lt;AppRouter /&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;lt;/MainLayout&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; &amp;nbsp; &amp;lt;/AuthProvider&amp;gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp; );&lt;/div&gt;&lt;div&gt;}&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="270" x="-1020" y="-2660" as="geometry" />
        </mxCell>
        <mxCell id="LqXvwYY59BlQr5JXUkB3-5" parent="1" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;strokeWidth=16;" value="21.04.26" vertex="1">
          <mxGeometry height="9860" width="9900" x="-9830" y="-15050" as="geometry" />
