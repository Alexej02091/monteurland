        <mxCell id="WHHgOg5_DndE_inDnti3-7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Kurz gesagt: &lt;strong&gt;Ja.&lt;/strong&gt;  &lt;br/&gt;Die &lt;em&gt;Inserate&lt;/em&gt; sind genau die &lt;strong&gt;Artikel/Wohnungsangebote&lt;/strong&gt;, die du auf der &lt;strong&gt;Startseite&lt;/strong&gt; und in der &lt;strong&gt;Suche&lt;/strong&gt; siehst.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit du es ganz klar einordnen kannst, hier die Struktur:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🏡 &lt;strong&gt;Was ist ein Inserat?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ein &lt;em&gt;Inserat&lt;/em&gt; ist ein einzelnes Wohnungsangebot, das folgende Daten enthält:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Titel&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Preis&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bilder&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beschreibung&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Größe, Zimmer, Ort&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Vermieter‑Infos&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;ID (z. B. &lt;code&gt;/inserat/12&lt;/code&gt;)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🏠 &lt;strong&gt;Wo erscheinen Inserate?&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div tabindex=&quot;0&quot; role=&quot;group&quot; aria-label=&quot;Scrollbare Tabelle&quot;&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Bereich&lt;/th&gt;&lt;th&gt;Beschreibung&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;Startseite&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Zeigt eine Auswahl an Inseraten (z. B. neueste, beliebte)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;Suchseite&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Zeigt gefilterte Inserate (Preis, Ort, Größe, etc.)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;Detailseite&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Zeigt ein einzelnes Inserat mit allen Infos&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;Favoriten&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Gespeicherte Inserate eines Gesuchters&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;strong&gt;Vermieter‑Dashboard&lt;/strong&gt;&lt;/td&gt;&lt;td&gt;Vermieter sieht seine eigenen Inserate&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;button aria-label=&quot;Tabelle kopieren&quot; type=&quot;button&quot; data-testid=&quot;copy-table-button&quot; data-spatial-navigation-autofocus=&quot;false&quot; data-tooltip-state=&quot;closed&quot;&gt;&lt;svg viewBox=&quot;0 0 20 20&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8 2C6.89543 2 6 2.89543 6 4V14C6 15.1046 6.89543 16 8 16H14C15.1046 16 16 15.1046 16 14V4C16 2.89543 15.1046 2 14 2H8ZM7 4C7 3.44772 7.44772 3 8 3H14C14.5523 3 15 3.44772 15 4V14C15 14.5523 14.5523 15 14 15H8C7.44772 15 7 14.5523 7 14V4ZM4 6.00001C4 5.25973 4.4022 4.61339 5 4.26758V14.5C5 15.8807 6.11929 17 7.5 17H13.7324C13.3866 17.5978 12.7403 18 12 18H7.5C5.567 18 4 16.433 4 14.5V6.00001Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;button aria-label=&quot;Tabelle herunterladen&quot; type=&quot;button&quot; data-testid=&quot;download-table-button&quot; data-spatial-navigation-autofocus=&quot;false&quot; data-tooltip-state=&quot;closed&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M18.2498 20.5009C18.664 20.5008 19 20.8365 19 21.2507C19 21.6649 18.6644 22.0008 18.2502 22.0009L5.25022 22.0047C4.836 22.0048 4.5 21.6691 4.5 21.2549C4.5 20.8407 4.83557 20.5048 5.24978 20.5047L18.2498 20.5009ZM11.6482 2.01271L11.75 2.00586C12.1297 2.00586 12.4435 2.28801 12.4932 2.65409L12.5 2.75586L12.499 16.4409L16.2208 12.7205C16.4871 12.4543 16.9038 12.4301 17.1974 12.648L17.2815 12.7206C17.5477 12.9869 17.5719 13.4036 17.354 13.6972L17.2814 13.7813L12.2837 18.7779C12.0176 19.044 11.6012 19.0683 11.3076 18.8507L11.2235 18.7782L6.22003 13.7816C5.92694 13.4889 5.92661 13.014 6.21931 12.7209C6.48539 12.4545 6.90204 12.43 7.1958 12.6477L7.27997 12.7202L10.999 16.4339L11 2.75586C11 2.37616 11.2822 2.06237 11.6482 2.01271L11.75 2.00586L11.6482 2.01271Z&quot; fill=&quot;currentColor&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🔗 &lt;strong&gt;Wie hängt die Detailseite damit zusammen?&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Die Route:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;Route path=&quot;/inserat/:id&quot; element={&amp;lt;InseratDetail /&amp;gt;} /&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;bedeutet:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn jemand auf ein Inserat klickt (z. B. auf der Startseite),&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;wird er zur Detailseite weitergeleitet,&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;und die ID bestimmt, welches Inserat angezeigt wird.&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Beispiel:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;/inserat/1&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;/inserat/42&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;code&gt;/inserat/123&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;Zusammenfassung&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ Inserate = Artikel/Wohnungsangebote&lt;br/&gt;✔ Werden auf Startseite &amp;amp; Suche angezeigt&lt;br/&gt;✔ Detailseite zeigt ein einzelnes Inserat&lt;br/&gt;✔ Route &lt;code&gt;/inserat/:id&lt;/code&gt; ist öffentlich&lt;br/&gt;✔ Jede Rolle darf Inserate sehen&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wenn du möchtest, können wir jetzt:&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;👉 die &lt;strong&gt;Startseite&lt;/strong&gt; so bauen, dass sie echte Inserate anzeigt&lt;br/&gt;👉 die &lt;strong&gt;Suchseite&lt;/strong&gt; verbessern&lt;br/&gt;👉 die &lt;strong&gt;Inserate‑API&lt;/strong&gt; vorbereiten&lt;br/&gt;👉 ein &lt;strong&gt;Karten‑Layout&lt;/strong&gt; für Inserate erstellen&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir, was du willst.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="1180" width="680" x="-6460" y="-8800" as="geometry" />
        </mxCell>
        <mxCell id="WHHgOg5_DndE_inDnti3-8" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Alles klar — &lt;strong&gt;du hast absolut recht&lt;/strong&gt;:&lt;br/&gt;👉 &lt;strong&gt;Bevor wir eine Detailseite brauchen, müssen wir überhaupt Inserate auf dem Bildschirm sehen.&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Die Detailseite ist nur sinnvoll, &lt;strong&gt;wenn man auf ein Inserat klicken kann&lt;/strong&gt;.&lt;br/&gt;Also bauen wir jetzt:&lt;/span&gt;&lt;/p&gt;&lt;h1&gt;✅ &lt;strong&gt;Inserate auf der Startseite anzeigen&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Wir machen das in 3 Schritten:&lt;/span&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Fake‑Inserate erstellen&lt;/strong&gt; (später API‑ready)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Startseite so umbauen, dass sie Inserate rendert&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Klick führt zur Detailseite &lt;/strong&gt;&lt;code&gt;/inserat/:id&lt;/code&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Damit bekommst du sofort sichtbare Inserate.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 &lt;strong&gt;1. Fake‑Inserate erstellen&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Erstelle eine Datei:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;src/data/inserate.js&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Inhalt:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;const inserate = [&lt;br/&gt;  {&lt;br/&gt;    id: 1,&lt;br/&gt;    title: &quot;Moderne Wohnung im Zentrum&quot;,&lt;br/&gt;    price: 1200,&lt;br/&gt;    image: &quot;https://via.placeholder.com/400x250?text=Wohnung+1&quot;,&lt;br/&gt;    location: &quot;Hamburg&quot;,&lt;br/&gt;  },&lt;br/&gt;  {&lt;br/&gt;    id: 2,&lt;br/&gt;    title: &quot;Gemütliches Apartment&quot;,&lt;br/&gt;    price: 950,&lt;br/&gt;    image: &quot;https://via.placeholder.com/400x250?text=Wohnung+2&quot;,&lt;br/&gt;    location: &quot;Berlin&quot;,&lt;br/&gt;  },&lt;br/&gt;  {&lt;br/&gt;    id: 3,&lt;br/&gt;    title: &quot;Großzügige 3‑Zimmer Wohnung&quot;,&lt;br/&gt;    price: 1450,&lt;br/&gt;    image: &quot;https://via.placeholder.com/400x250?text=Wohnung+3&quot;,&lt;br/&gt;    location: &quot;München&quot;,&lt;br/&gt;  }&lt;br/&gt;];&lt;br/&gt;&lt;br/&gt;export default inserate;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 &lt;strong&gt;2. Startseite so umbauen, dass Inserate angezeigt werden&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Öffne:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;Code&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;src/pages/Home.jsx&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ersetze den Inhalt durch:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import inserate from &quot;../data/inserate&quot;;&lt;br/&gt;import { Link } from &quot;react-router-dom&quot;;&lt;br/&gt;&lt;br/&gt;export default function Home() {&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div&amp;gt;&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Aktuelle Inserate&amp;lt;/h1&amp;gt;&lt;br/&gt;&lt;br/&gt;      &amp;lt;div className=&quot;row g-4&quot;&amp;gt;&lt;br/&gt;        {inserate.map((item) =&amp;gt; (&lt;br/&gt;          &amp;lt;div key={item.id} className=&quot;col-md-4&quot;&amp;gt;&lt;br/&gt;            &amp;lt;div className=&quot;card h-100&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;              &amp;lt;img&lt;br/&gt;                src={item.image}&lt;br/&gt;                className=&quot;card-img-top&quot;&lt;br/&gt;                alt={item.title}&lt;br/&gt;              /&amp;gt;&lt;br/&gt;&lt;br/&gt;              &amp;lt;div className=&quot;card-body&quot;&amp;gt;&lt;br/&gt;                &amp;lt;h5 className=&quot;card-title&quot;&amp;gt;{item.title}&amp;lt;/h5&amp;gt;&lt;br/&gt;                &amp;lt;p className=&quot;card-text&quot;&amp;gt;&lt;br/&gt;                  &amp;lt;strong&amp;gt;{item.price} €&amp;lt;/strong&amp;gt; / Monat&amp;lt;br /&amp;gt;&lt;br/&gt;                  {item.location}&lt;br/&gt;                &amp;lt;/p&amp;gt;&lt;br/&gt;&lt;br/&gt;                &amp;lt;Link&lt;br/&gt;                  to={`/inserat/${item.id}`}&lt;br/&gt;                  className=&quot;btn btn-primary w-100&quot;&lt;br/&gt;                &amp;gt;&lt;br/&gt;                  Details ansehen&lt;br/&gt;                &amp;lt;/Link&amp;gt;&lt;br/&gt;              &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;            &amp;lt;/div&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        ))}&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧩 &lt;strong&gt;3. Routing prüfen&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;In &lt;code&gt;AppRouter.jsx&lt;/code&gt; muss stehen:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;&amp;lt;Route path=&quot;/inserat/:id&quot; element={&amp;lt;InseratDetail /&amp;gt;} /&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎉 &lt;strong&gt;Jetzt passiert Folgendes:&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ Auf der Startseite erscheinen &lt;strong&gt;3 Inserate&lt;/strong&gt;  &lt;br/&gt;✔ Jedes Inserat hat &lt;strong&gt;Bild, Titel, Preis, Ort&lt;/strong&gt;  &lt;br/&gt;✔ Klick auf „Details ansehen“ öffnet die &lt;strong&gt;Inserat‑Detailseite&lt;/strong&gt;  &lt;br/&gt;✔ Die Detailseite funktioniert bereits (wir haben sie gebaut)&lt;br/&gt;✔ Alles ist später leicht mit API ersetzbar&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🚀 &lt;strong&gt;Nächster Schritt (wenn du willst)&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich kann dir jetzt helfen mit:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Suchseite mit echten Filtern&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Inserate aus API laden statt Fake‑Daten&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Favoriten‑Button funktionsfähig machen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Anfrage‑Button funktionsfähig machen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Pagination (Seitenblätterung)&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Design verbessern (Grid, Icons, Badges)&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir einfach, was du als Nächstes möchtest.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="2240" width="680" x="-6450" y="-7500" as="geometry" />
        </mxCell>
        <mxCell id="WHHgOg5_DndE_inDnti3-9" parent="1" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=240;height=30;strokeColor=#FF9933;strokeWidth=7;" value="src/data/" vertex="1">
          <mxGeometry height="1540" width="1210" x="17490" y="-3180" as="geometry" />
        </mxCell>
        <mxCell id="WHHgOg5_DndE_inDnti3-11" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontColor=#ffffff;fontSize=31;align=left;verticalAlign=top;spacingLeft=5;fillColor=#0050ef;strokeColor=#001DBC;" value="&lt;font color=&quot;#ffffff&quot;&gt;Fake Inserat&lt;/font&gt;" vertex="1">
          <mxGeometry height="250" width="370" x="17540" y="-3080" as="geometry" />
        </mxCell>
        <mxCell id="WHHgOg5_DndE_inDnti3-12" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontColor=#ffffff;fontSize=31;align=left;verticalAlign=top;spacingLeft=5;fillColor=#6a00ff;strokeColor=#3700CC;" value="&lt;font style=&quot;color: rgb(255, 255, 255);&quot;&gt;inserate.js&lt;/font&gt;" vertex="1">
          <mxGeometry height="170" width="270" x="17590" y="-3010" as="geometry" />
        </mxCell>
        <mxCell id="WHHgOg5_DndE_inDnti3-13" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ja, das können wir machen — &lt;strong&gt;aber ich muss dir vorher etwas Wichtiges erklären&lt;/strong&gt;, damit du keine falschen Erwartungen hast:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;🔒 &lt;strong&gt;Ein echtes Schreiben in eine JSON‑Datei ist im Browser NICHT möglich.&lt;/strong&gt;&lt;/h3&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Der Browser darf &lt;strong&gt;keine Dateien auf deinem Computer verändern&lt;/strong&gt; (aus Sicherheitsgründen).&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;ABER:&lt;/span&gt;&lt;/p&gt;&lt;h3&gt;✅ &lt;strong&gt;Wir können eine Fake‑Registrierung bauen, die Daten speichert in:&lt;/strong&gt;&lt;/h3&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;localStorage&lt;/strong&gt; (funktioniert sofort, bleibt gespeichert)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;einer JSON‑Datei im Projekt&lt;/strong&gt;, die wir &lt;em&gt;simulieren&lt;/em&gt; (Fake‑Backend)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;einem Fake‑Server wie JSON‑Server&lt;/strong&gt; (echtes Schreiben in JSON möglich)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich zeige dir &lt;strong&gt;alle drei Varianten&lt;/strong&gt;, und du entscheidest, welche du willst.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🟢 &lt;strong&gt;VARIANTE A — Fake‑Registrierung mit localStorage (empfohlen für Frontend‑Demo)&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ funktioniert sofort&lt;br&gt;✔ keine Installation&lt;br&gt;✔ Daten bleiben gespeichert&lt;br&gt;✔ perfekt für Login/Registrierung Demo&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;📁 1. Registrierungsseite erstellen&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;src/pages/Register.jsx&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { useState } from &quot;react&quot;;&lt;br&gt;&lt;br&gt;export default function Register() {&lt;br&gt;  const [email, setEmail] = useState(&quot;&quot;);&lt;br&gt;  const [password, setPassword] = useState(&quot;&quot;);&lt;br&gt;&lt;br&gt;  const handleRegister = (e) =&amp;gt; {&lt;br&gt;    e.preventDefault();&lt;br&gt;&lt;br&gt;    const users = JSON.parse(localStorage.getItem(&quot;users&quot;)) || [];&lt;br&gt;&lt;br&gt;    // Prüfen ob User existiert&lt;br&gt;    if (users.find((u) =&amp;gt; u.email === email)) {&lt;br&gt;      alert(&quot;Benutzer existiert bereits!&quot;);&lt;br&gt;      return;&lt;br&gt;    }&lt;br&gt;&lt;br&gt;    // Neuen User speichern&lt;br&gt;    users.push({&lt;br&gt;      email,&lt;br&gt;      password,&lt;br&gt;      role: &quot;gesuchter&quot; // Standardrolle&lt;br&gt;    });&lt;br&gt;&lt;br&gt;    localStorage.setItem(&quot;users&quot;, JSON.stringify(users));&lt;br&gt;&lt;br&gt;    alert(&quot;Registrierung erfolgreich!&quot;);&lt;br&gt;  };&lt;br&gt;&lt;br&gt;  return (&lt;br&gt;    &amp;lt;div className=&quot;col-md-6 mx-auto&quot;&amp;gt;&lt;br&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Registrieren&amp;lt;/h1&amp;gt;&lt;br&gt;&lt;br&gt;      &amp;lt;form onSubmit={handleRegister}&amp;gt;&lt;br&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;E-Mail&amp;lt;/label&amp;gt;&lt;br&gt;          &amp;lt;input&lt;br&gt;            type=&quot;email&quot;&lt;br&gt;            className=&quot;form-control&quot;&lt;br&gt;            value={email}&lt;br&gt;            onChange={(e) =&amp;gt; setEmail(e.target.value)}&lt;br&gt;            required&lt;br&gt;          /&amp;gt;&lt;br&gt;        &amp;lt;/div&amp;gt;&lt;br&gt;&lt;br&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Passwort&amp;lt;/label&amp;gt;&lt;br&gt;          &amp;lt;input&lt;br&gt;            type=&quot;password&quot;&lt;br&gt;            className=&quot;form-control&quot;&lt;br&gt;            value={password}&lt;br&gt;            onChange={(e) =&amp;gt; setPassword(e.target.value)}&lt;br&gt;            required&lt;br&gt;          /&amp;gt;&lt;br&gt;        &amp;lt;/div&amp;gt;&lt;br&gt;&lt;br&gt;        &amp;lt;button className=&quot;btn btn-primary w-100&quot;&amp;gt;Registrieren&amp;lt;/button&amp;gt;&lt;br&gt;      &amp;lt;/form&amp;gt;&lt;br&gt;    &amp;lt;/div&amp;gt;&lt;br&gt;  );&lt;br&gt;}&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;📁 2. Route hinzufügen&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;In &lt;strong&gt;AppRouter.jsx&lt;/strong&gt;:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import Register from &quot;../pages/Register&quot;;&lt;br&gt;&lt;br&gt;&amp;lt;Route path=&quot;/register&quot; element={&amp;lt;Register /&amp;gt;} /&amp;gt;&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h2&gt;📁 3. Login anpassen (damit er localStorage nutzt)&lt;/h2&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;src/pages/Login.jsx&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { useState } from &quot;react&quot;;&lt;br&gt;import { useAuth } from &quot;../context/AuthContext&quot;;&lt;br&gt;&lt;br&gt;export default function Login() {&lt;br&gt;  const { login } = useAuth();&lt;br&gt;  const [email, setEmail] = useState(&quot;&quot;);&lt;br&gt;  const [password, setPassword] = useState(&quot;&quot;);&lt;br&gt;&lt;br&gt;  const handleLogin = (e) =&amp;gt; {&lt;br&gt;    e.preventDefault();&lt;br&gt;&lt;br&gt;    const users = JSON.parse(localStorage.getItem(&quot;users&quot;)) || [];&lt;br&gt;&lt;br&gt;    const user = users.find(&lt;br&gt;      (u) =&amp;gt; u.email === email &amp;amp;&amp;amp; u.password === password&lt;br&gt;    );&lt;br&gt;&lt;br&gt;    if (!user) {&lt;br&gt;      alert(&quot;Falsche Login-Daten!&quot;);&lt;br&gt;      return;&lt;br&gt;    }&lt;br&gt;&lt;br&gt;    login(user.email, user.role);&lt;br&gt;  };&lt;br&gt;&lt;br&gt;  return (&lt;br&gt;    &amp;lt;div className=&quot;col-md-6 mx-auto&quot;&amp;gt;&lt;br&gt;      &amp;lt;h1 className=&quot;mb-4&quot;&amp;gt;Login&amp;lt;/h1&amp;gt;&lt;br&gt;&lt;br&gt;      &amp;lt;form onSubmit={handleLogin}&amp;gt;&lt;br&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;E-Mail&amp;lt;/label&amp;gt;&lt;br&gt;          &amp;lt;input&lt;br&gt;            type=&quot;email&quot;&lt;br&gt;            className=&quot;form-control&quot;&lt;br&gt;            value={email}&lt;br&gt;            onChange={(e) =&amp;gt; setEmail(e.target.value)}&lt;br&gt;            required&lt;br&gt;          /&amp;gt;&lt;br&gt;        &amp;lt;/div&amp;gt;&lt;br&gt;&lt;br&gt;        &amp;lt;div className=&quot;mb-3&quot;&amp;gt;&lt;br&gt;          &amp;lt;label className=&quot;form-label&quot;&amp;gt;Passwort&amp;lt;/label&amp;gt;&lt;br&gt;          &amp;lt;input&lt;br&gt;            type=&quot;password&quot;&lt;br&gt;            className=&quot;form-control&quot;&lt;br&gt;            value={password}&lt;br&gt;            onChange={(e) =&amp;gt; setPassword(e.target.value)}&lt;br&gt;            required&lt;br&gt;          /&amp;gt;&lt;br&gt;        &amp;lt;/div&amp;gt;&lt;br&gt;&lt;br&gt;        &amp;lt;button className=&quot;btn btn-primary w-100&quot;&amp;gt;Login&amp;lt;/button&amp;gt;&lt;br&gt;      &amp;lt;/form&amp;gt;&lt;br&gt;    &amp;lt;/div&amp;gt;&lt;br&gt;  );&lt;br&gt;}&lt;br&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;&lt;br&gt;&lt;/h1&gt;" vertex="1">
