        </mxCell>
        <mxCell id="Tj8YYApBm8QszppxP4FJ-121" parent="LqXvwYY59BlQr5JXUkB3-140" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;strokeColor=#FF69B4;width=130;height=30;container=0;" value="Dashboard.jsx" vertex="1">
          <mxGeometry height="542.39" width="456.94" as="geometry" />
