        <mxCell id="4BVwiWuFCP3b-g3bp4e4-39" parent="4BVwiWuFCP3b-g3bp4e4-49" style="shape=umlFrame;whiteSpace=wrap;html=1;pointerEvents=0;width=140;height=30;" value="ProtectedRoute" vertex="1">
