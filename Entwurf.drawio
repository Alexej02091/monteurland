        <mxCell id="0zXxf4QrsDUB6JAg3p7k-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Perfekt — wir bauen jetzt eine &lt;strong&gt;komplette Inserat‑Detailseite&lt;/strong&gt;, die:&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;eine Inserat‑ID aus der URL liest&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Fake‑Daten lädt (später API‑ready)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bilder, Titel, Preis, Beschreibung anzeigt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Favoriten‑Button enthält&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Anfrage‑Button für Gesuchter enthält&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Bootstrap‑ready ist&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;sofort in dein Routing passt&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Ich gebe dir &lt;strong&gt;eine fertige, saubere, professionelle Version&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🏡 &lt;code&gt;src/pages/InseratDetail.jsx&lt;/code&gt;&lt;strong&gt; (komplette Datei)&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import { useParams } from &quot;react-router-dom&quot;;&lt;br/&gt;import { useEffect, useState } from &quot;react&quot;;&lt;br/&gt;&lt;br/&gt;export default function InseratDetail() {&lt;br/&gt;  const { id } = useParams();&lt;br/&gt;&lt;br/&gt;  const [data, setData] = useState(null);&lt;br/&gt;  const [loading, setLoading] = useState(true);&lt;br/&gt;&lt;br/&gt;  // Fake-Daten (später API)&lt;br/&gt;  useEffect(() =&amp;gt; {&lt;br/&gt;    setLoading(true);&lt;br/&gt;&lt;br/&gt;    const fakeInserat = {&lt;br/&gt;      id,&lt;br/&gt;      title: &quot;Moderne Wohnung im Zentrum&quot;,&lt;br/&gt;      price: 1200,&lt;br/&gt;      description:&lt;br/&gt;        &quot;Helle, moderne Wohnung im Herzen der Stadt. Perfekt für Singles oder Paare.&quot;,&lt;br/&gt;      images: [&lt;br/&gt;        &quot;https://via.placeholder.com/800x400?text=Wohnung+Bild+1&quot;,&lt;br/&gt;        &quot;https://via.placeholder.com/800x400?text=Wohnung+Bild+2&quot;,&lt;br/&gt;        &quot;https://via.placeholder.com/800x400?text=Wohnung+Bild+3&quot;&lt;br/&gt;      ],&lt;br/&gt;      location: &quot;Hamburg, Innenstadt&quot;,&lt;br/&gt;      size: 65,&lt;br/&gt;      rooms: 2&lt;br/&gt;    };&lt;br/&gt;&lt;br/&gt;    setTimeout(() =&amp;gt; {&lt;br/&gt;      setData(fakeInserat);&lt;br/&gt;      setLoading(false);&lt;br/&gt;    }, 500);&lt;br/&gt;  }, [id]);&lt;br/&gt;&lt;br/&gt;  if (loading) {&lt;br/&gt;    return &amp;lt;p className=&quot;text-center mt-5&quot;&amp;gt;Lade Inserat...&amp;lt;/p&amp;gt;;&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  if (!data) {&lt;br/&gt;    return &amp;lt;p className=&quot;text-center mt-5&quot;&amp;gt;Inserat nicht gefunden.&amp;lt;/p&amp;gt;;&lt;br/&gt;  }&lt;br/&gt;&lt;br/&gt;  return (&lt;br/&gt;    &amp;lt;div className=&quot;col-lg-10 mx-auto&quot;&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* Titel */}&lt;br/&gt;      &amp;lt;h1 className=&quot;mb-3&quot;&amp;gt;{data.title}&amp;lt;/h1&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* Preis */}&lt;br/&gt;      &amp;lt;h3 className=&quot;text-primary mb-4&quot;&amp;gt;{data.price} € / Monat&amp;lt;/h3&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* Bildergalerie */}&lt;br/&gt;      &amp;lt;div id=&quot;carouselExample&quot; className=&quot;carousel slide mb-4&quot;&amp;gt;&lt;br/&gt;        &amp;lt;div className=&quot;carousel-inner&quot;&amp;gt;&lt;br/&gt;          {data.images.map((img, index) =&amp;gt; (&lt;br/&gt;            &amp;lt;div&lt;br/&gt;              key={index}&lt;br/&gt;              className={`carousel-item ${index === 0 ? &quot;active&quot; : &quot;&quot;}`}&lt;br/&gt;            &amp;gt;&lt;br/&gt;              &amp;lt;img src={img} className=&quot;d-block w-100&quot; alt=&quot;Wohnung&quot; /&amp;gt;&lt;br/&gt;            &amp;lt;/div&amp;gt;&lt;br/&gt;          ))}&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;button&lt;br/&gt;          className=&quot;carousel-control-prev&quot;&lt;br/&gt;          type=&quot;button&quot;&lt;br/&gt;          data-bs-target=&quot;#carouselExample&quot;&lt;br/&gt;          data-bs-slide=&quot;prev&quot;&lt;br/&gt;        &amp;gt;&lt;br/&gt;          &amp;lt;span className=&quot;carousel-control-prev-icon&quot;&amp;gt;&amp;lt;/span&amp;gt;&lt;br/&gt;        &amp;lt;/button&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;button&lt;br/&gt;          className=&quot;carousel-control-next&quot;&lt;br/&gt;          type=&quot;button&quot;&lt;br/&gt;          data-bs-target=&quot;#carouselExample&quot;&lt;br/&gt;          data-bs-slide=&quot;next&quot;&lt;br/&gt;        &amp;gt;&lt;br/&gt;          &amp;lt;span className=&quot;carousel-control-next-icon&quot;&amp;gt;&amp;lt;/span&amp;gt;&lt;br/&gt;        &amp;lt;/button&amp;gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* Details */}&lt;br/&gt;      &amp;lt;div className=&quot;row mb-4&quot;&amp;gt;&lt;br/&gt;        &amp;lt;div className=&quot;col-md-4&quot;&amp;gt;&lt;br/&gt;          &amp;lt;div className=&quot;card p-3&quot;&amp;gt;&lt;br/&gt;            &amp;lt;h5&amp;gt;Details&amp;lt;/h5&amp;gt;&lt;br/&gt;            &amp;lt;p&amp;gt;&amp;lt;strong&amp;gt;Ort:&amp;lt;/strong&amp;gt; {data.location}&amp;lt;/p&amp;gt;&lt;br/&gt;            &amp;lt;p&amp;gt;&amp;lt;strong&amp;gt;Größe:&amp;lt;/strong&amp;gt; {data.size} m²&amp;lt;/p&amp;gt;&lt;br/&gt;            &amp;lt;p&amp;gt;&amp;lt;strong&amp;gt;Zimmer:&amp;lt;/strong&amp;gt; {data.rooms}&amp;lt;/p&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;div className=&quot;col-md-8&quot;&amp;gt;&lt;br/&gt;          &amp;lt;div className=&quot;card p-3&quot;&amp;gt;&lt;br/&gt;            &amp;lt;h5&amp;gt;Beschreibung&amp;lt;/h5&amp;gt;&lt;br/&gt;            &amp;lt;p&amp;gt;{data.description}&amp;lt;/p&amp;gt;&lt;br/&gt;          &amp;lt;/div&amp;gt;&lt;br/&gt;        &amp;lt;/div&amp;gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;&lt;br/&gt;      {/* Aktionen */}&lt;br/&gt;      &amp;lt;div className=&quot;d-flex gap-3&quot;&amp;gt;&lt;br/&gt;        &amp;lt;button className=&quot;btn btn-outline-primary&quot;&amp;gt;&lt;br/&gt;          ❤️ Zu Favoriten hinzufügen&lt;br/&gt;        &amp;lt;/button&amp;gt;&lt;br/&gt;&lt;br/&gt;        &amp;lt;button className=&quot;btn btn-success&quot;&amp;gt;&lt;br/&gt;          📩 Anfrage senden&lt;br/&gt;        &amp;lt;/button&amp;gt;&lt;br/&gt;      &amp;lt;/div&amp;gt;&lt;br/&gt;    &amp;lt;/div&amp;gt;&lt;br/&gt;  );&lt;br/&gt;}&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧭 &lt;strong&gt;Routing eintragen&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;In deiner &lt;code&gt;AppRouter.jsx&lt;/code&gt;:&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;import InseratDetail from &quot;../pages/InseratDetail&quot;;&lt;br/&gt;&lt;br/&gt;&amp;lt;Route path=&quot;/inserat/:id&quot; element={&amp;lt;InseratDetail /&amp;gt;} /&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎨 &lt;strong&gt;Was die Seite jetzt kann&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;✔ Bilder‑Slider&lt;br/&gt;✔ Titel, Preis, Beschreibung&lt;br/&gt;✔ Standort, Größe, Zimmer&lt;br/&gt;✔ Favoriten‑Button&lt;br/&gt;✔ Anfrage‑Button&lt;br/&gt;✔ Fake‑Daten → später API&lt;br/&gt;✔ Responsive&lt;br/&gt;✔ Bootstrap‑ready&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🚀 &lt;strong&gt;Nächste sinnvolle Schritte&lt;/strong&gt;&lt;/h1&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Hier sind die besten Erweiterungen:&lt;/span&gt;&lt;/p&gt;&lt;ol start=&quot;1&quot;&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;API‑Service bauen (axios)&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Inserat‑Detailseite mit echter API verbinden&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Favoriten‑Button mit AuthContext verknüpfen&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Anfrage‑Workflow starten&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;&lt;strong&gt;Suchseite verbessern (Filter, Sortierung)&lt;/strong&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Sag mir, womit wir weitermachen.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="2640" width="675" x="-6455" y="-12380" as="geometry" />
        </mxCell>
        <mxCell id="0zXxf4QrsDUB6JAg3p7k-26" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;urz und klar: &lt;strong&gt;Die Inserat‑Detailseite gehört zu &lt;/strong&gt;&lt;em&gt;&lt;strong&gt;allen Rollen&lt;/strong&gt;&lt;/em&gt; – also &lt;strong&gt;öffentlich&lt;/strong&gt;.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Warum?&lt;/span&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Jeder Besucher (auch ohne Login) muss Inserate ansehen können&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Gesuchter kann dort Favoriten setzen &amp;amp; Anfragen senden&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Vermieter kann seine eigenen Inserate prüfen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Admin kann alles sehen&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;white-space-collapse: preserve;&quot;&gt;Darum ist die Route &lt;strong&gt;nicht geschützt&lt;/strong&gt; und steht im öffentlichen Bereich deines Routers.&lt;/span&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🧭 &lt;strong&gt;So gehört die Route in deinen AppRouter&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;jsx&lt;button type=&quot;button&quot; title=&quot;Codeausschnitt reduzieren&quot; aria-expanded=&quot;true&quot;&gt;&lt;svg viewBox=&quot;0 0 24 24&quot; fill=&quot;currentColor&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;&gt;&lt;path d=&quot;M8.46967 4.21967C8.17678 4.51256 8.17678 4.98744 8.46967 5.28033L15.1893 12L8.46967 18.7197C8.17678 19.0126 8.17678 19.4874 8.46967 19.7803C8.76256 20.0732 9.23744 20.0732 9.53033 19.7803L16.7803 12.5303C17.0732 12.2374 17.0732 11.7626 16.7803 11.4697L9.53033 4.21967C9.23744 3.92678 8.76256 3.92678 8.46967 4.21967Z&quot;&gt;&lt;/path&gt;&lt;/svg&gt;&lt;/button&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div class=&quot;rounded-b-xl bg-background-static-850 px-4 pb-1.5 dark:bg-background-static-900&quot;&gt;&lt;div style=&quot;white-space: pre;&quot;&gt;&lt;pre&gt;&lt;code&gt;// Öffentliche Routen&lt;br/&gt;&amp;lt;Route path=&quot;/&quot; element={&amp;lt;Home /&amp;gt;} /&amp;gt;&lt;br/&gt;&amp;lt;Route path=&quot;/search&quot; element={&amp;lt;Search /&amp;gt;} /&amp;gt;&lt;br/&gt;&amp;lt;Route path=&quot;/inserat/:id&quot; element={&amp;lt;InseratDetail /&amp;gt;} /&amp;gt;   // ✔ öffentlich&lt;br/&gt;&amp;lt;Route path=&quot;/login&quot; element={&amp;lt;Login /&amp;gt;} /&amp;gt;&lt;br/&gt;&amp;lt;Route path=&quot;/unauthorized&quot; element={&amp;lt;Unauthorized /&amp;gt;} /&amp;gt;&lt;br/&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;h1&gt;🎯 &lt;strong&gt;Warum nicht geschützt?&lt;/strong&gt;&lt;/h1&gt;&lt;div&gt;&lt;div&gt;&lt;div tabindex=&quot;0&quot; role=&quot;group&quot; aria-label=&quot;Scrollbare Tabelle&quot;&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Rolle&lt;/th&gt;&lt;th&gt;Zugriff&lt;/th&gt;&lt;th&gt;Grund&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Gast&lt;/td&gt;&lt;td&gt;✔&lt;/td&gt;&lt;td&gt;Inserate ansehen ohne Login&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Gesuchter&lt;/td&gt;&lt;td&gt;✔&lt;/td&gt;&lt;td&gt;Favoriten, Anfragen&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Vermieter&lt;/td&gt;&lt;td&gt;✔&lt;/td&gt;&lt;td&gt;Eigene Inserate prüfen&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Admin&lt;/td&gt;&lt;td&gt;✔&lt;/td&gt;&lt;td&gt;Kontrolle &amp;amp; Monitoring&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;&lt;div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;button aria-label=&quot;Tabelle kopieren&quot; type=&quot;button&quot; d