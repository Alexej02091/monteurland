        <mxCell id="LqXvwYY59BlQr5JXUkB3-172" parent="1" style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacingLeft=5;" value="PHASE 4 – Business‑Features (Erweiterungen)&lt;div&gt;&lt;table&gt;&lt;thead&gt;&lt;tr&gt;&lt;th&gt;Feature&lt;/th&gt;&lt;th&gt;Priorität&lt;/th&gt;&lt;th&gt;Beschreibung&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody&gt;&lt;tr&gt;&lt;td&gt;Chat zwischen Vermieter &amp;amp; Gesuchter&lt;/td&gt;&lt;td&gt;⭐⭐⭐⭐⭐&lt;/td&gt;&lt;td&gt;Echtzeit oder polling&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Buchungsworkflow&lt;/td&gt;&lt;td&gt;⭐⭐⭐⭐&lt;/td&gt;&lt;td&gt;Anfrage → Bestätigung → Vertrag&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Bewertungen &amp;amp; Reviews&lt;/td&gt;&lt;td&gt;⭐⭐⭐&lt;/td&gt;&lt;td&gt;Vermieter/Mieter bewerten&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Dokumenten‑Upload&lt;/td&gt;&lt;td&gt;⭐⭐⭐&lt;/td&gt;&lt;td&gt;Mietvertrag, Unterlagen&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;Kalender‑Integration&lt;/td&gt;&lt;td&gt;⭐⭐&lt;/td&gt;&lt;td&gt;Verfügbarkeiten anzeigen&lt;/td&gt;&lt;/tr&gt;&lt;/tbody&gt;&lt;/table&gt;&lt;/div&gt;" vertex="1">
